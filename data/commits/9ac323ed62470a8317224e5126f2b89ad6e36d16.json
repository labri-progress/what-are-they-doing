xtures/string_adversarial_cases.json\",\n+      \"crates/fnp-string/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"string_adversarial_center_zero\",\n+    \"input_strings\": [\"hello\"],\n+    \"width\": 0,\n+    \"expected_strings\": [\"hello\"]\n+  },\n+  {\n+    \"id\": \"str_count_overlapping\",\n+    \"operation\": \"str_count\",\n+    \"seed\": 10509,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-string-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/string_adversarial_cases.json\",\n+      \"crates/fnp-string/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"string_adversarial_count_overlap\",\n+    \"input_strings\": [\"aaaa\"],\n+    \"search_substr\": \"aa\",\n+    \"expected_behavior\": \"non_overlapping_count\"\n+  },\n+  {\n+    \"id\": \"str_multiply_by_zero\",\n+    \"operation\": \"str_multiply\",\n+    \"seed\": 10510,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-string-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/string_adversarial_cases.json\",\n+      \"crates/fnp-string/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"string_adversarial_mul_zero\",\n+    \"input_strings\": [\"hello\"],\n+    \"multiplier\": 0,\n+    \"expected_strings\": [\"\"]\n+  },\n+  {\n+    \"id\": \"str_multiply_negative\",\n+    \"operation\": \"str_multiply\",\n+    \"seed\": 10511,\n+    \"mode\": \"hardened\",\n+    \"env_fingerprint\": \"fnp-string-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/string_adversarial_cases.json\",\n+      \"crates/fnp-string/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"string_adversarial_mul_negative\",\n+    \"input_strings\": [\"hello\"],\n+    \"multiplier\": -1,\n+    \"expected_strings\": [\"\"]\n+  },\n+  {\n+    \"id\": \"str_isdigit_empty\",\n+    \"operation\": \"str_isdigit\",\n+    \"seed\": 10512,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-stri