      "patch": "@@ -0,0 +1,180 @@\n+[\n+  {\n+    \"id\": \"str_empty_string_lower\",\n+    \"operation\": \"str_lower\",\n+    \"seed\": 10501,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-string-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/string_adversarial_cases.json\",\n+      \"crates/fnp-string/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"string_adversarial_empty\",\n+    \"input_strings\": [\"\"],\n+    \"expected_strings\": [\"\"]\n+  },\n+  {\n+    \"id\": \"str_whitespace_only_strip\",\n+    \"operation\": \"str_strip\",\n+    \"seed\": 10502,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-string-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/string_adversarial_cases.json\",\n+      \"crates/fnp-string/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"string_adversarial_whitespace_only\",\n+    \"input_strings\": [\"   \", \"\\t\\n\\r\", \"  \\t  \"],\n+    \"expected_strings\": [\"\", \"\", \"\"]\n+  },\n+  {\n+    \"id\": \"str_find_empty_substr\",\n+    \"operation\": \"str_find\",\n+    \"seed\": 10503,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-string-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/string_adversarial_cases.json\",\n+      \"crates/fnp-string/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"string_adversarial_find_empty\",\n+    \"input_strings\": [\"hello\", \"world\"],\n+    \"search_substr\": \"\",\n+    \"expected_behavior\": \"returns_zero\"\n+  },\n+  {\n+    \"id\": \"str_find_not_found\",\n+    \"operation\": \"str_find\",\n+    \"seed\": 10504,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-string-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/string_adversarial_cases.json\",\n+      \"crates/fnp-string/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"string_adversarial_find_missing\",\n+