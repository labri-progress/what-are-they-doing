      "patch": "@@ -21,7 +21,8 @@ fi\n \n # --- Unit tests (same filter as `bun run test:unit:parallel`) ---\n echo \"Running unit tests...\"\n-bun run test:unit:parallel\n+# Cap default parallelism for pre-commit to balance speed and laptop thermals.\n+TEST_JOBS=\"${TEST_JOBS:-8}\" bun run test:unit:parallel\n if [ $? -ne 0 ]; then\n   echo \"Tests failed. Fix tests before committing.\"\n   exit 1"
