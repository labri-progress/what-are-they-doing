      "raw_url": "https://github.com/Dicklesworthstone/beads_viewer/raw/2fd688f7de076fdc88e7495ac313575653921c5d/pkg%2Fexport%2Fviewer_assets%2Findex.html",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/beads_viewer/contents/pkg%2Fexport%2Fviewer_assets%2Findex.html?ref=2fd688f7de076fdc88e7495ac313575653921c5d",
      "patch": "@@ -3188,13 +3188,22 @@ <h2 class=\"text-base font-semibold text-gray-900 dark:text-white leading-snug li\n       <div class=\"absolute bottom-4 left-4 pointer-events-auto transition-opacity duration-200\"\n            :class=\"graphDetailNode ? 'hidden md:block' : ''\">\n         <div class=\"bg-white/90 dark:bg-gray-800/90 backdrop-blur-sm rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-2 md:p-3\">\n-          <div class=\"text-xs text-gray-500 dark:text-gray-400 mb-1.5 md:mb-2\">Legend</div>\n-          <div class=\"flex flex-wrap gap-x-3 md:gap-x-4 gap-y-1 text-[10px] md:text-xs\">\n+          <div class=\"text-xs text-gray-500 dark:text-gray-400 mb-1.5 md:mb-2\" x-text=\"graphHeatmapActive ? 'Heatmap: ' + {pagerank:'PageRank',betweenness:'Betweenness',critical:'Critical Path',indegree:'In-Degree'}[graphSizeMetric] : 'Legend'\"></div>\n+          <!-- Status color legend (default) -->\n+          <div x-show=\"!graphHeatmapActive\" class=\"flex flex-wrap gap-x-3 md:gap-x-4 gap-y-1 text-[10px] md:text-xs\">\n             <div class=\"flex items-center gap-1\"><div class=\"w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-green-500\"></div> Open</div>\n             <div class=\"flex items-center gap-1\"><div class=\"w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-yellow-500\"></div> In Progress</div>\n             <div class=\"flex items-center gap-1\"><div class=\"w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-gray-400\"></div> Closed</div>\n             <div class=\"flex items-center gap-1\"><div class=\"w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-red-500\"></div> Blocked</div>\n           </div>\n+          <!-- Heatmap color scale (when heatmap is active) -->\n+          <div x-show=\"graphHeatmapActive\" class=\"text-[10px] md:text-xs\">\n+            <div class=\"flex items-center gap-2\">\n+              <span class=\"text-gray-500 dark:text-gray-400\">Low</span>\n+              <div class=\"flex-1 h-2.5 md:h-3 rounded-full\" style=\"background: linear-gradient(to right, hsl(120,80%,50%), hsl(90,80%,50%), hsl(60,80%,50%), hsl(30,80%,50%), hsl(0,80%,50%));\"></div>\n+              <span class=\"text-gray-500 dark:text-gray-400\">High</span>\n+            </div>\n+          </div>\n           <!-- Keyboard hints only on desktop -->\n           <div class=\"hidden md:block mt-2 pt-2 border-t border-gray-200 dark:border-gray-700 text-xs text-gray-500 dark:text-gray-400 space-y-1\">\n             <div>Click nodes for details \u2022 Drag to pan \u2022 Scroll to zoom</div>"
