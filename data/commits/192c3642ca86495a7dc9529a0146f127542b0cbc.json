      "filename": "rust-toolchain.toml",
      "status": "added",
      "additions": 3,
      "deletions": 0,
      "changes": 3,
      "blob_url": "https://github.com/Dicklesworthstone/bio_inspired_nanochat/blob/192c3642ca86495a7dc9529a0146f127542b0cbc/rust-toolchain.toml",
      "raw_url": "https://github.com/Dicklesworthstone/bio_inspired_nanochat/raw/192c3642ca86495a7dc9529a0146f127542b0cbc/rust-toolchain.toml",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/bio_inspired_nanochat/contents/rust-toolchain.toml?ref=192c3642ca86495a7dc9529a0146f127542b0cbc",
      "patch": "@@ -0,0 +1,3 @@\n+[toolchain]\n+channel = \"nightly\"\n+components = [\"rustfmt\", \"clippy\"]"
