      "patch": "@@ -4,9 +4,7 @@ FROM ${BUILD_FROM}\n RUN apk add --no-cache python3 py3-pip && \\\n     pip3 install --no-cache-dir --break-system-packages tinytuya paho-mqtt\n \n-COPY run.sh /\n COPY water_quality.py /\n+COPY run.sh /etc/services.d/water-quality/run\n \n-RUN chmod a+x /run.sh\n-\n-CMD [ \"/run.sh\" ]\n+RUN chmod a+x /etc/services.d/water-quality/run"
