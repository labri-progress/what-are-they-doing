      "patch": "@@ -0,0 +1,80 @@\n+{\n+  \"version\": \"kc-mission-v1\",\n+  \"name\": \"linkerd-10003-destination-routing-to-incorrect-pod-ips\",\n+  \"missionClass\": \"solution\",\n+  \"author\": \"KubeStellar Bot\",\n+  \"authorGithub\": \"kubestellar\",\n+  \"mission\": {\n+    \"title\": \"linkerd: Destination routing to incorrect Pod IPs\",\n+    \"description\": \"Destination routing to incorrect Pod IPs. Users encounter: \\\"<img width=\\\"946\\\" alt=\\\"example\\\" src=\\\"https://user-images.githubusercontent.com/10061593/207413753-674\\\".\",\n+    \"type\": \"troubleshoot\",\n+    \"status\": \"completed\",\n+    \"steps\": [\n+      {\n+        \"title\": \"Identify linkerd troubleshoot symptoms\",\n+        \"description\": \"Check for the issue in your linkerd deployment:\\n```bash\\nkubectl get pods -n linkerd -l app.kubernetes.io/name=linkerd\\nkubectl logs -l app.kubernetes.io/name=linkerd -n linkerd --tail=100 | grep -i error\\n```\\nLook for error: `<img width=\\\"946\\\" alt=\\\"example\\\" src=\\\"https://user-images.githubusercontent.com/10061593/207413753-674f5ce7-75ac-4366-a037`\"\n+      },\n+      {\n+        \"title\": \"Review linkerd configuration\",\n+        \"description\": \"Inspect the relevant linkerd configuration:\\n```bash\\nkubectl get all -n linkerd -l app.kubernetes.io/name=linkerd\\nkubectl get configmap -n linkerd -l app.kubernetes.io/part-of=linkerd\\n```\\n### What is the issue?\\n\\nWe are seeing routing issues between LinkerD containers.\"\n+      },\n+      {\n+        \"title\": \"Apply the fix for Destination routing to incorrect Pod IPs\",\n+        \"description\": \"When endpoints are removed from an EndpointSlice resource, the destination controller builds a list of addresses to remove.  However, if any of the removed endpoints have a Pod as their targetRef, we will attempt to fetch that pod to build the address to remove.  If that pod has already been\\n```yaml\\nRunning for svc: gatekeeper...\\n\\nK8S EndpointSlice (gatekeeper-z24b8)\\ncount: 15\\nips: [10.12.0.101 10.12.14.49 10.12.27.134 10.12.5.7 10.12.37.11 10.12.39.183 10.12.8.59 10.12.18.209 10.12.3.11 10.12.43.4 10.12.51.222 10.12.10.15 10.12.2.148 10.12.28.67 10.12.32.94]\\n\\nLinkerd\\ncount: 16\\nips: [10.12.27.134 10.12.51.222 10.12.19.29 10.12.0.101 10.12.14.49 10.12.32.94 10.12.5.7 10.12.43.4 10.12.2.148 10.12.28.67 10.12.18.209 10.12.10.15 10.12.39.183 10.12.8.59 10.12.37.11 10.12.3.11]\\n\\n\\nMismatch?\\ncount: 1\\nips: [10.12.19.29]\\n```\"\n+      },\n+      {\n+        \"title\": \"Confirm Destination routing to incorrect Pod IPs is resolved\",\n+        \"description\": \"Verify the fix by checking that the original error no longer occurs:\\n```bash\\nkubectl logs -l app.kubernetes.io/name=linkerd -n linkerd --tail=50 --since=5m\\nkubectl get events -n linkerd --sort-by='.lastTimestamp' | tail -10\\n```\\nConfirm that `<img width=\\\"946\\\" alt=\\\"example\\\" src=\\\"https://user-images.githubusercontent.com/10061593/207413753-674f5ce7-75ac-4366-a037` no longer appears in logs.\"\n+      }\n+    ],\n+    \"resolution\": {\n+      \"summary\": \"When endpoints are removed from an EndpointSlice resource, the destination controller builds a list of addresses to remove.  However, if any of the removed endpoints have a Pod as their targetRef, we will attempt to fetch that pod to build the address to remove.\",\n+      \"codeSnippets\": [\n+        \"Running for svc: gatekeeper...\\n\\nK8S EndpointSlice (gatekeeper-z24b8)\\ncount: 15\\nips: [10.12.0.101 10.12.14.49 10.12.27.134 10.12.5.7 10.12.37.11 10.12.39.183 10.12.8.59 10.12.18.209 10.12.3.11 10.12.43.4 10.12.51.222 10.12.10.15 10.12.2.148 10.12.28.67 10.12.32.94]\\n\\nLinkerd\\ncount: 16\\nips: [10.12.27.134 10.12.51.222 10.12.19.29 10.12.0.101 10.12.14.49 10.12.32.94 10.12.5.7 10.12.43.4 10.12.2.148 10.12.28.67 10.12.18.209 10.12.10.15 10.12.39.183 10.12.8.59 10.12.37.11 10.12.3.11]\\n\\n\\nMismatch?\\ncount: 1\\nips: [10.12.19.29]\",\n+        \"{\\\"message\\\":\\\"Failed to connect\\\",\\\"error\\\":\\\"connect timed out after 1s\\\"}\\n{\\\"message\\\":\\\"Failed to connect\\\",\\\"error\\\":\\\"connect timed out after 1s\\\"}\\n{\\\"message\\\":\\\"Failed to connect\\\",\\\"error\\\":\\\"connect timed out after 1s\\\"}\\n{\\\"message\\\":\\\"Failed to connect\\\",\\\"error\\\":\\\"connect timed out after 1s\\\"}\\n{\\\"message\\\":\\\"Failed to connect\\\",\\\"error\\\":\\\"connect timed out after 1s\\\"}\"\n+      ]\n+    }\n+  },\n+  \"metadata\": {\n+    \"tags\": [\n+      \"linkerd\",\n+      \"graduated\",\n+      \"networking\",\n+      \"troubleshoot\"\n+    ],\n+    \"cncfProjects\": [\n+      \"linkerd\"\n+    ],\n+    \"targetResourceKinds\": [\n+      \"Pod\",\n+      \"Clusterrole\",\n+      \"Service\"\n+    ],\n+    \"difficulty\": \"advanced\",\n+    \"issueTypes\": [\n+      \"troubleshoot\"\n+    ],\n+    \"maturity\": \"graduated\",\n+    \"sourceUrls\": {\n+      \"issue\": \"https://github.com/linkerd/linkerd2/issues/10003\",\n+      \"repo\": \"https://github.com/linkerd/linkerd2\",\n+      \"pr\": \"https://github.com/linkerd/linkerd2/pull/10013\"\n+    },\n+    \"reactions\": 6,\n+    \"comments\": 4,\n+    \"synthesizedBy\": \"copilot\"\n+  },\n+  \"prerequisites\": {\n+    \"kubernetes\": \">=1.24\",\n+    \"tools\": [\n+      \"kubectl\"\n+    ],\n+    \"description\": \"A running Kubernetes cluster with linkerd installed or the issue environment reproducible.\"\n+  },\n+  \"security\": {\n+    \"scannedAt\": \"2026-03-21T06:19:19.610Z\",\n+    \"scannerVersion\": \"cncf-gen-3.0.0\",\n+    \"sanitized\": true,\n+    \"findings\": []\n+  }\n+}"
