{
  "message": "fix(connectors): add 30-second HTTP client timeout to 10 connectors\n\nAdd .timeout(Duration::from_secs(30)) to the reqwest::Client::builder()\nchain in connectors that previously had no timeout configured. Without\nthis, requests to unresponsive upstream APIs would hang indefinitely,\npotentially exhausting connection pools and blocking agent workflows.\n\nAffected: browser, google-ai, microsoft365, notion, pinecone, plaid,\nqdrant, twilio, youtube, zendesk\n\nCo-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>",
  "files": [
    {
      "sha": "b4e563958653cedd6d66a22b1488140e8fc3d318",
      "filename": "connectors/browser/src/client.rs",
      "status": "modified",
      "additions": 1,
      "deletions": 0,
      "changes": 1,
      "blob_url": "https://github.com/Dicklesworthstone/flywheel_connectors/blob/172de7a5d6855ba71b2bfe0c7f7ff548cb44789c/connectors%2Fbrowser%2Fsrc%2Fclient.rs",
      "raw_url": "https://github.com/Dicklesworthstone/flywheel_connectors/raw/172de7a5d6855ba71b2bfe0c7f7ff548cb44789c/connectors%2Fbrowser%2Fsrc%2Fclient.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/flywheel_connectors/contents/connectors%2Fbrowser%2Fsrc%2Fclient.rs?ref=172de7a5d6855ba71b2bfe0c7f7ff548cb44789c",
      "patch": "@@ -112,6 +112,7 @@ impl BrowserClient {\n         let http = Client::builder()\n             .default_headers(headers)\n             .user_agent(\"fcp-browser/0.1.0\")\n+            .timeout(Duration::from_secs(30))\n             .build()\n             .map_err(BrowserError::Http)?;\n "
    },
