{
  "message": "\u2728 Show kubectl fallback when no events found\n\nWhen filtered events are empty, show the kubectl command\nto fetch events directly instead of just \"No events found\".\n\nCo-Authored-By: Claude Opus 4.5 <noreply@anthropic.com>\nSigned-off-by: Andrew Anderson <andy@clubanderson.com>",
  "files": [
    {
      "sha": "5ccd16a08f0e49506cc32e8774d65f8d48355989",
      "filename": "web/src/components/drilldown/views/EventsDrillDown.tsx",
      "status": "modified",
      "additions": 25,
      "deletions": 2,
      "changes": 27,
      "blob_url": "https://github.com/kubestellar/console/blob/bf1942cc86d448cb1673209d7f661df9fa4cd855/web%2Fsrc%2Fcomponents%2Fdrilldown%2Fviews%2FEventsDrillDown.tsx",
      "raw_url": "https://github.com/kubestellar/console/raw/bf1942cc86d448cb1673209d7f661df9fa4cd855/web%2Fsrc%2Fcomponents%2Fdrilldown%2Fviews%2FEventsDrillDown.tsx",
      "contents_url": "https://api.github.com/repos/kubestellar/console/contents/web%2Fsrc%2Fcomponents%2Fdrilldown%2Fviews%2FEventsDrillDown.tsx?ref=bf1942cc86d448cb1673209d7f661df9fa4cd855",
      "patch": "@@ -164,8 +164,31 @@ export function EventsDrillDown({ data }: Props) {\n       </div>\n \n       {filteredEvents.length === 0 && (\n-        <div className=\"text-center py-12\">\n-          <p className=\"text-muted-foreground\">No events found</p>\n+        <div className=\"space-y-4\">\n+          <div className=\"text-center py-6\">\n+            <p className=\"text-muted-foreground\">No events found for {objectName || clusterShort}</p>\n+            <p className=\"text-xs text-muted-foreground mt-1\">Events may have expired or require authentication</p>\n+          </div>\n+\n+          {/* Kubectl fallback */}\n+          <div className=\"p-4 rounded-lg bg-card/50 border border-border\">\n+            <h4 className=\"text-sm font-semibold text-foreground mb-3 flex items-center gap-2\">\n+              <Terminal className=\"w-4 h-4\" />\n+              Get Events via kubectl\n+            </h4>\n+            <div className=\"flex items-center justify-between p-2 rounded bg-background/50 font-mono text-xs\">\n+              <code className=\"text-muted-foreground truncate\">\n+                kubectl --context {clusterShort} get events{objectName ? ` --field-selector involvedObject.name=${objectName}` : ''}{namespace ? ` -n ${namespace}` : ' -A'} --sort-by=.lastTimestamp\n+              </code>\n+              <button\n+                onClick={copyCommand}\n+                className=\"ml-2 p-1 hover:bg-card rounded flex-shrink-0\"\n+                title=\"Copy command\"\n+              >\n+                {copied ? <CheckCircle className=\"w-3 h-3 text-green-400\" /> : <Copy className=\"w-3 h-3 text-muted-foreground\" />}\n+              </button>\n+            </div>\n+          </div>\n         </div>\n       )}\n     </div>"
    }
  ]
}
