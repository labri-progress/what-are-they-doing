      "patch": "@@ -1,6 +1,10 @@\n #!/usr/bin/env bash\n-# Stub `ntm` for swarm-tick tests. Emits the fixture for `--robot-status`.\n+# Stub `ntm` for swarm-tick tests. Emits the active fixture's ntm robot data.\n case \"${1:-}\" in\n     --robot-status) cat \"$FIXTURE_DIR/ntm_robot_status.json\" ;;\n+    --robot-health=*) cat \"$FIXTURE_DIR/ntm_robot_health.json\" ;;\n+    --robot-alerts) cat \"$FIXTURE_DIR/ntm_robot_alerts.json\" ;;\n+    --robot-assign=*) cat \"$FIXTURE_DIR/ntm_robot_assign.json\" ;;\n+    conflicts) cat \"$FIXTURE_DIR/ntm_conflicts.json\" ;;\n     *) : ;;\n esac"
