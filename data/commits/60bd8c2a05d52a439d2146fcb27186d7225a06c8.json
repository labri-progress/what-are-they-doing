      "patch": "@@ -1680,3 +1680,4 @@\n {\"id\":\"frankenpandas-cod1m03\",\"title\":\"Freeze Series and DataFrame display output as golden artifacts\",\"description\":\"Testing-golden-artifacts pass found fp-frame display tests only asserting substrings, so column alignment, row ordering, and summary layout regressions would pass silently. Add committed display goldens and compare exact rendered output in the existing display tests.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"bug\",\"assignee\":\"cod_1\",\"created_at\":\"2026-04-28T20:49:52.840355956Z\",\"created_by\":\"cod_1\",\"updated_at\":\"2026-04-28T20:54:49.134809075Z\",\"closed_at\":\"2026-04-28T20:54:49.134809075Z\",\"close_reason\":\"Added committed Series/DataFrame display golden files, wired exact golden comparison into fp-frame display tests, and validated fmt/test/check/clippy/UBS.\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"labels\":[\"testing-golden-artifacts\",\"fp-frame\",\"display\",\"regression-tests\"]}\n {\"id\":\"frankenpandas-cod1m04\",\"title\":\"Make DataFrame::info include documented memory usage\",\"description\":\"Reality-check pass found fp-frame documents DataFrame::info as reporting dtypes, non-null counts, and memory, while the implementation only emitted shape/index/non-null/dtype. Add the existing shallow memory accounting to info output and lock it in the info test.\",\"status\":\"in_progress\",\"priority\":2,\"issue_type\":\"bug\",\"assignee\":\"cod_1\",\"created_at\":\"2026-04-28T20:56:41.781673952Z\",\"created_by\":\"cod_1\",\"updated_at\":\"2026-04-28T20:56:41.781673952Z\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"labels\":[\"reality-check-for-project\",\"fp-frame\",\"info\",\"docs-code-parity\"]}\n {\"id\":\"frankenpandas-review-inf01\",\"title\":\"fix(columnar): python_mod_f64 returns nan for finite % infinity\",\"description\":\"REVIEWER finding: The formula `lhs - floor(lhs/rhs) * rhs` in python_mod_f64 (line 611-612) produces nan for finite values modulo infinity where Python returns correct values:\\n- 5.0 % inf \u2192 should be 5.0, returns nan\\n- -5.0 % inf \u2192 should be inf, returns nan\\n- 5.0 % -inf \u2192 should be -inf, returns nan\\n- -5.0 % -inf \u2192 should be -5.0, returns nan\\n\\nRoot cause: floor(x/inf) * inf = 0 * inf = nan. Introduced in fe06882.\\n\\nFix: Add infinity check - if rhs.is_infinite(), return lhs when same sign, rhs when opposite sign.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"bug\",\"assignee\":\"cc_1\",\"created_at\":\"2026-04-28T21:15:00.000000000Z\",\"created_by\":\"cc_1\",\"updated_at\":\"2026-04-28T22:35:00.000000000Z\",\"closed_at\":\"2026-04-28T22:35:00.000000000Z\",\"close_reason\":\"Fixed in cb3f2d5 - added infinity check to python_mod_f64 with 10 test cases covering all combinations.\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"labels\":[\"reviewer\",\"fp-columnar\",\"modulo\",\"infinity\",\"edge-case\"],\"priority\":2,\"issue_type\":\"bug\",\"assignee\":null,\"created_at\":\"2026-04-28T21:15:00.000000000Z\",\"created_by\":\"cc_1\",\"updated_at\":\"2026-04-28T21:15:00.000000000Z\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"labels\":[\"reviewer\",\"fp-columnar\",\"modulo\",\"infinity\",\"edge-case\"]}\n+{\"id\":\"frankenpandas-cod1m04\",\"title\":\"Make DataFrame::info include documented memory usage\",\"description\":\"Reality-check pass found fp-frame documents DataFrame::info as reporting dtypes, non-null counts, and memory, while the implementation only emitted shape/index/non-null/dtype. Add the existing shallow memory accounting to info output and lock it in the info test.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"bug\",\"assignee\":\"cc_1\",\"created_at\":\"2026-04-28T20:56:41.781673952Z\",\"created_by\":\"cod_1\",\"updated_at\":\"2026-04-28T22:40:00.000000000Z\",\"closed_at\":\"2026-04-28T22:40:00.000000000Z\",\"close_reason\":\"Already implemented - info() includes Memory usage line and test dataframe_info_basic verifies it.\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"labels\":[\"reality-check-for-project\",\"fp-frame\",\"info\",\"docs-code-parity\"]}"
