      "raw_url": "https://github.com/Dicklesworthstone/flywheel_connectors/raw/531b2a95bed54fa6cebbda13621cf3703a04acd5/crates%2Ffcp-conformance%2Fsrc%2Fvectors%2Fcapability.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/flywheel_connectors/contents/crates%2Ffcp-conformance%2Fsrc%2Fvectors%2Fcapability.rs?ref=531b2a95bed54fa6cebbda13621cf3703a04acd5",
      "patch": "@@ -88,8 +88,16 @@ impl CapabilityTokenGoldenVector {\n             checkpoint_seq: None,\n             not_before: 1_700_000_000,\n             expires: 1_700_086_400,\n-            expected_claims_cbor: \"a83a0001000678186e6f64653a7072696d6172792e6d6573682e74732e6e65743a000100036c6167656e743a636c617564653a000100028174646973636f72642e73656e645f6d6573736167653a00010001667a3a776f726b3a00010000706361703a646973636f72642e73656e64016c6e6f64653a7072696d617279041a65554280051a6553f100\".into(),\n-            expected_token_cbor: \"\".into(),\n+            // RFC 8949 canonical CBOR map-key order: positives first\n+            // (by value), then negatives by ascending N = -1-key.\n+            // Regenerated after 6df66c79 switched the encoder from\n+            // numeric-i64 ordering to RFC 8949 bytewise lex (br-b6rtk).\n+            // The `expected_claims_cbor` reflects raw CwtClaims::to_cbor\n+            // (8 entries) BEFORE `CoseToken::sign` synthesizes the\n+            // current SCHEMA_VERSION; `expected_token_cbor` reflects the\n+            // signed payload AFTER synthesis (9 entries).\n+            expected_claims_cbor: \"a8016c6e6f64653a7072696d617279041a65554280051a6553f1003a00010000706361703a646973636f72642e73656e643a00010001667a3a776f726b3a000100028174646973636f72642e73656e645f6d6573736167653a000100036c6167656e743a636c617564653a0001000678186e6f64653a7072696d6172792e6d6573682e74732e6e6574\".into(),\n+            expected_token_cbor: \"\".into(),\n         }\n     }\n \n@@ -116,8 +124,8 @@ impl CapabilityTokenGoldenVector {\n             checkpoint_seq: Some(42),\n             not_before: 1_700_000_000,\n             expires: 1_700_172_800,\n-            expected_claims_cbor: \"\".into(),\n-            expected_token_cbor: \"\".into(),\n+            expected_claims_cbor: \"\".into(),\n+            expected_token_cbor: \"\".into(),\n         }\n     }\n \n@@ -149,8 +157,8 @@ impl CapabilityTokenGoldenVector {\n             checkpoint_seq: None,\n             not_before: 1_700_000_000,\n             expires: 1_700_003_600,\n-            expected_claims_cbor: \"\".into(),\n-            expected_token_cbor: \"\".into(),\n+            expected_claims_cbor: \"\".into(),\n+            expected_token_cbor: \"\".into(),\n         }\n     }\n \n@@ -638,4 +646,50 @@ mod tests {\n         assert_eq!(verified.get_capability_id(), Some(\"cap:github.manage\"));\n         assert_eq!(verified.get_zone_id(), Some(\"z:public\"));\n     }\n+\n+    /// ONE-SHOT REGEN HELPER \u2014 run with `-- --ignored --nocapture` to dump\n+    /// the current canonical claims + token CBOR for each golden vector.\n+    /// Use the output to refresh `expected_claims_cbor` / `expected_token_cbor`\n+    /// whenever the canonical encoder changes (e.g. after 6df66c79's RFC\n+    /// 8949 reordering). Ignored by default so it doesn't run in CI.\n+    #[test]\n+    #[ignore]\n+    fn regen_dump_golden_bytes() {\n+        use chrono::DateTime;\n+        use fcp_crypto::cose::{CoseToken, CwtClaims};\n+        use fcp_crypto::ed25519::Ed25519SigningKey;\n+\n+        for v in CapabilityTokenGoldenVector::load_all() {\n+            let sk_bytes: [u8; 32] = hex::decode(&v.signing_key).unwrap().try_into().unwrap();\n+            let sk = Ed25519SigningKey::from_bytes(&sk_bytes).unwrap();\n+\n+            let nbf = DateTime::from_timestamp(v.not_before, 0).unwrap();\n+            let exp = DateTime::from_timestamp(v.expires, 0).unwrap();\n+            let mut claims = CwtClaims::new()\n+                .issuer(&v.issuer)\n+                .capability_id(&v.capability_id)\n+                .zone_id(&v.zone_id)\n+                .principal_id(&v.principal_id)\n+                .issuing_node(&v.issuing_node)\n+                .not_before(nbf)\n+                .expiration(exp);\n+            let ops: Vec<&str> = v.operations.iter().map(String::as_str).collect();\n+            claims = claims.operations(&ops);\n+            if let Some(ref h) = v.holder_node {\n+                claims = claims.holder_node(h);\n+            }\n+            if let (Some(chk_id_hex), Some(chk_seq)) = (&v.checkpoint_id, v.checkpoint_seq) {\n+                let chk = hex::decode(chk_id_hex).unwrap();\n+                claims = claims.checkpoint(&chk, chk_seq);\n+            }\n+\n+            let claims_cbor = claims.to_cbor().unwrap();\n+            let token = CoseToken::sign(&sk, &claims).unwrap();\n+            let token_cbor = token.to_cbor().unwrap();\n+\n+            eprintln!(\"---- {} ----\", v.description);\n+            eprintln!(\"claims: {}\", hex::encode(&claims_cbor));\n+            eprintln!(\"token:  {}\", hex::encode(&token_cbor));\n+        }\n+    }\n }"
    }
  ]
