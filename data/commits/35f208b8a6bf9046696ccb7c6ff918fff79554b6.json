      "patch": "@@ -2385,6 +2385,158 @@\n         ]\n       }\n     },\n+    {\n+      \"name\": \"keys_setup_prefix_a\",\n+      \"now_ms\": 801,\n+      \"argv\": [\"SET\", \"prefix_alpha\", \"1\"],\n+      \"expect\": {\"kind\": \"simple\", \"value\": \"OK\"}\n+    },\n+    {\n+      \"name\": \"keys_setup_prefix_b\",\n+      \"now_ms\": 801,\n+      \"argv\": [\"SET\", \"prefix_beta\", \"2\"],\n+      \"expect\": {\"kind\": \"simple\", \"value\": \"OK\"}\n+    },\n+    {\n+      \"name\": \"keys_setup_suffix\",\n+      \"now_ms\": 801,\n+      \"argv\": [\"SET\", \"gamma_suffix\", \"3\"],\n+      \"expect\": {\"kind\": \"simple\", \"value\": \"OK\"}\n+    },\n+    {\n+      \"name\": \"keys_prefix_wildcard\",\n+      \"now_ms\": 802,\n+      \"argv\": [\"KEYS\", \"prefix_*\"],\n+      \"expect\": {\n+        \"kind\": \"any_array\"\n+      }\n+    },\n+    {\n+      \"name\": \"keys_suffix_wildcard\",\n+      \"now_ms\": 802,\n+      \"argv\": [\"KEYS\", \"*_suffix\"],\n+      \"expect\": {\n+        \"kind\": \"array\",\n+        \"value\": [{\"kind\": \"bulk\", \"value\": \"gamma_suffix\"}]\n+      }\n+    },\n+    {\n+      \"name\": \"keys_char_class_setup_a\",\n+      \"now_ms\": 803,\n+      \"argv\": [\"SET\", \"cc_a\", \"1\"],\n+      \"expect\": {\"kind\": \"simple\", \"value\": \"OK\"}\n+    },\n+    {\n+      \"name\": \"keys_char_class_setup_b\",\n+      \"now_ms\": 803,\n+      \"argv\": [\"SET\", \"cc_b\", \"2\"],\n+      \"expect\": {\"kind\": \"simple\", \"value\": \"OK\"}\n+    },\n+    {\n+      \"name\": \"keys_char_class_setup_x\",\n+      \"now_ms\": 803,\n+      \"argv\": [\"SET\", \"cc_x\", \"3\"],\n+      \"expect\": {\"kind\": \"simple\", \"value\": \"OK\"}\n+    },\n+    {\n+      \"name\": \"keys_char_class_match\",\n+      \"now_ms\": 804,\n+      \"argv\": [\"KEYS\", \"cc_[ab]\"],\n+      \"expect\": {\n+        \"kind\": \"any_array\"\n+      }\n+    },\n+    {\n+      \"name\": \"keys_negated_char_class\",\n+      \"now_ms\": 804,\