d_not_found\",\n+      \"now_ms\": 1000,\n+      \"argv\": [\"KEYS\", \"keys_will_expire\"],\n+      \"expect\": {\n+        \"kind\": \"array\",\n+        \"value\": []\n+      }\n+    },\n+    {\n+      \"name\": \"keys_literal_brackets_setup\",\n+      \"now_ms\": 1001,\n+      \"argv\": [\"SET\", \"key[1]\", \"bracketed\"],\n+      \"expect\": {\"kind\": \"simple\", \"value\": \"OK\"}\n+    },\n+    {\n+      \"name\": \"keys_literal_brackets_match\",\n+      \"now_ms\": 1002,\n+      \"argv\": [\"KEYS\", \"key\\\\[1\\\\]\"],\n+      \"expect\": {\n+        \"kind\": \"array\",\n+        \"value\": [{\"kind\": \"bulk\", \"value\": \"key[1]\"}]\n+      }\n+    },\n     {\n       \"name\": \"dump_missing_key\",\n       \"now_ms\": 900,"
