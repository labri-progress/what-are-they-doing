{
  "message": "\ud83c\udf31 Add Prow and stale/unstale governance workflows (#51)\n\nAdds standard governance workflows using reusable callers from\nllm-d/llm-d-infra: signed commits, Prow commands, auto-merge,\nremove-lgtm, non-main gatekeeper, stale/unstale issue management.\n\nScope reduced to governance-only (no Go/Docker/test changes).\n\nSigned-off-by: Andrew Anderson <andy@clubanderson.com>",
  "files": [
    {
      "sha": "2b374bf714a29bced1184a0fe51a22f601ebb621",
      "filename": ".github/workflows/ci-signed-commits.yml",
      "status": "added",
      "additions": 9,
      "deletions": 0,
      "changes": 9,
      "blob_url": "https://github.com/llm-d-incubation/batch-gateway/blob/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fci-signed-commits.yml",
      "raw_url": "https://github.com/llm-d-incubation/batch-gateway/raw/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fci-signed-commits.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/batch-gateway/contents/.github%2Fworkflows%2Fci-signed-commits.yml?ref=7c52de0a0836355b84deac278cfb0151252a188d",
      "patch": "@@ -0,0 +1,9 @@\n+name: Check Signed Commits\n+on: pull_request_target\n+\n+jobs:\n+  signed-commits:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-signed-commits.yml@main\n+    permissions:\n+      contents: read\n+      pull-requests: write"
    },
    {
      "sha": "eda8951abdc1fce969da6af89f3d9595970fe215",
      "filename": ".github/workflows/non-main-gatekeeper.yml",
      "status": "added",
      "additions": 11,
      "deletions": 0,
      "changes": 11,
      "blob_url": "https://github.com/llm-d-incubation/batch-gateway/blob/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fnon-main-gatekeeper.yml",
      "raw_url": "https://github.com/llm-d-incubation/batch-gateway/raw/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fnon-main-gatekeeper.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/batch-gateway/contents/.github%2Fworkflows%2Fnon-main-gatekeeper.yml?ref=7c52de0a0836355b84deac278cfb0151252a188d",
      "patch": "@@ -0,0 +1,11 @@\n+name: Non-Main Gatekeeper\n+on:\n+  pull_request:\n+    types: [opened, edited, synchronize, reopened]\n+\n+permissions:\n+  pull-requests: write\n+\n+jobs:\n+  gatekeeper:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-non-main-gatekeeper.yml@main"
    },
    {
      "sha": "6fe0b234dd4fc24f0ad123da21f3b171a53cd2f3",
      "filename": ".github/workflows/prow-github.yml",
      "status": "added",
      "additions": 12,
      "deletions": 0,
      "changes": 12,
      "blob_url": "https://github.com/llm-d-incubation/batch-gateway/blob/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fprow-github.yml",
      "raw_url": "https://github.com/llm-d-incubation/batch-gateway/raw/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fprow-github.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/batch-gateway/contents/.github%2Fworkflows%2Fprow-github.yml?ref=7c52de0a0836355b84deac278cfb0151252a188d",
      "patch": "@@ -0,0 +1,12 @@\n+name: Prow Commands\n+on:\n+  issue_comment:\n+    types: [created]\n+\n+permissions:\n+  issues: write\n+  pull-requests: write\n+\n+jobs:\n+  prow:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-prow-commands.yml@main"
    },
    {
      "sha": "1fd13b292a416824dc9764afd1345a15f4ddfff7",
      "filename": ".github/workflows/prow-pr-automerge.yml",
      "status": "added",
      "additions": 12,
      "deletions": 0,
      "changes": 12,
      "blob_url": "https://github.com/llm-d-incubation/batch-gateway/blob/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fprow-pr-automerge.yml",
      "raw_url": "https://github.com/llm-d-incubation/batch-gateway/raw/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fprow-pr-automerge.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/batch-gateway/contents/.github%2Fworkflows%2Fprow-pr-automerge.yml?ref=7c52de0a0836355b84deac278cfb0151252a188d",
      "patch": "@@ -0,0 +1,12 @@\n+name: Prow Auto-merge\n+on:\n+  schedule:\n+    - cron: \"*/15 * * * *\"\n+\n+permissions:\n+  contents: write\n+  pull-requests: write\n+\n+jobs:\n+  auto-merge:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-prow-automerge.yml@main"
    },
    {
      "sha": "0e8a7714bd9265f2f722c760823ee64729a78d52",
      "filename": ".github/workflows/prow-pr-remove-lgtm.yml",
      "status": "added",
      "additions": 9,
      "deletions": 0,
      "changes": 9,
      "blob_url": "https://github.com/llm-d-incubation/batch-gateway/blob/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fprow-pr-remove-lgtm.yml",
      "raw_url": "https://github.com/llm-d-incubation/batch-gateway/raw/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fprow-pr-remove-lgtm.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/batch-gateway/contents/.github%2Fworkflows%2Fprow-pr-remove-lgtm.yml?ref=7c52de0a0836355b84deac278cfb0151252a188d",
      "patch": "@@ -0,0 +1,9 @@\n+name: Prow Remove LGTM\n+on: pull_request\n+\n+permissions:\n+  pull-requests: write\n+\n+jobs:\n+  remove-lgtm:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-prow-remove-lgtm.yml@main"
    },
    {
      "sha": "af558dbf495e44aad44b120aaca6f337bfca046b",
      "filename": ".github/workflows/stale.yml",
      "status": "added",
      "additions": 11,
      "deletions": 0,
      "changes": 11,
      "blob_url": "https://github.com/llm-d-incubation/batch-gateway/blob/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fstale.yml",
      "raw_url": "https://github.com/llm-d-incubation/batch-gateway/raw/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Fstale.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/batch-gateway/contents/.github%2Fworkflows%2Fstale.yml?ref=7c52de0a0836355b84deac278cfb0151252a188d",
      "patch": "@@ -0,0 +1,11 @@\n+name: Mark Stale Issues\n+on:\n+  schedule:\n+    - cron: '0 1 * * *'\n+\n+jobs:\n+  stale:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-stale.yml@main\n+    permissions:\n+      issues: write\n+      pull-requests: write"
    },
    {
      "sha": "5f85771742cbc7792ff7b74e3a252240b1403236",
      "filename": ".github/workflows/unstale.yml",
      "status": "added",
      "additions": 12,
      "deletions": 0,
      "changes": 12,
      "blob_url": "https://github.com/llm-d-incubation/batch-gateway/blob/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Funstale.yml",
      "raw_url": "https://github.com/llm-d-incubation/batch-gateway/raw/7c52de0a0836355b84deac278cfb0151252a188d/.github%2Fworkflows%2Funstale.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/batch-gateway/contents/.github%2Fworkflows%2Funstale.yml?ref=7c52de0a0836355b84deac278cfb0151252a188d",
      "patch": "@@ -0,0 +1,12 @@\n+name: Unstale Issues\n+on:\n+  issues:\n+    types: [reopened]\n+  issue_comment:\n+    types: [created]\n+\n+jobs:\n+  unstale:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-unstale.yml@main\n+    permissions:\n+      issues: write"
    }
  ]
}
