    {
      "sha": "18e3baddcb20bc3025fe8008a10539071ef45e7b",
      "filename": "fuzz/corpus/ft_serialize_raptorq_sidecar/10_boundary_512b_payload.txt",
      "status": "added",
      "additions": 1,
      "deletions": 0,
      "changes": 1,
      "blob_url": "https://github.com/Dicklesworthstone/frankentorch/blob/753203352ab54e2a0d38d6f9b570501ca6b20ff6/fuzz%2Fcorpus%2Fft_serialize_raptorq_sidecar%2F10_boundary_512b_payload.txt",
      "raw_url": "https://github.com/Dicklesworthstone/frankentorch/raw/753203352ab54e2a0d38d6f9b570501ca6b20ff6/fuzz%2Fcorpus%2Fft_serialize_raptorq_sidecar%2F10_boundary_512b_payload.txt",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankentorch/contents/fuzz%2Fcorpus%2Fft_serialize_raptorq_sidecar%2F10_boundary_512b_payload.txt?ref=753203352ab54e2a0d38d6f9b570501ca6b20ff6",
      "patch": "@@ -0,0 +1 @@\n+FrankenTorch RaptorQ sidecar boundary seed: deterministic payload recovery must keep exact byte length after padded source symbols. This seed is intentionally longer than the tiny JSON fixtures so the fuzzer enters the 65..512 recommended-symbol-size branch and exercises multiple systematic source symbols plus repair equations under the same deterministic seed."
    },
    {
      "sha": "b5e6db55f7359d8d1c0f114b7ab5e8308a78d977",
      "filename": "fuzz/fuzz_targets/ft_serialize_raptorq_sidecar.rs",
      "status": "added",
      "additions": 38,
      "deletions": 0,
      "changes": 38,
      "blob_url": "https://github.com/Dicklesworthstone/frankentorch/blob/753203352ab54e2a0d38d6f9b570501ca6b20ff6/fuzz%2Ffuzz_targets%2Fft_serialize_raptorq_sidecar.rs",
      "raw_url": "https://github.com/Dicklesworthstone/frankentorch/raw/753203352ab54e2a0d38d6f9b570501ca6b20ff6/fuzz%2Ffuzz_targets%2Fft_serialize_raptorq_sidecar.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankentorch/contents/fuzz%2Ffuzz_targets%2Fft_serialize_raptorq_sidecar.rs?ref=753203352ab54e2a0d38d6f9b570501ca6b20ff6",
      "patch": "@@ -0,0 +1,38 @@\n+#![no_main]\n+\n+use libfuzzer_sys::fuzz_target;\n+\n+const MAX_RAPTORQ_PAYLOAD_BYTES: usize = 2 * 1024;\n+\n+fuzz_target!(|data: &[u8]| {\n+    let repair_control = data.first().copied().unwrap_or(0);\n+    let payload_bytes = data;\n+    if payload_bytes.len() > MAX_RAPTORQ_PAYLOAD_BYTES {\n+        return;\n+    }\n+    let Ok(payload) = std::str::from_utf8(payload_bytes) else {\n+        return;\n+    };\n+\n+    let requested_repairs = usize::from(repair_control % 16);\n+    if let Ok((sidecar, proof)) = ft_serialize::generate_raptorq_sidecar(payload, requested_repairs)\n+    {\n+        assert_eq!(\n+            sidecar.schema_version,\n+            ft_serialize::RAPTORQ_SIDECAR_SCHEMA_VERSION\n+        );\n+        assert_eq!(sidecar.source_hash, proof.source_hash);\n+        assert!(sidecar.symbol_size > 0);\n+        assert!(sidecar.source_symbol_count > 0);\n+        assert_eq!(sidecar.repair_symbol_count, sidecar.repair_manifest.len());\n+        assert!(sidecar.repair_symbol_count >= requested_repairs.max(1));\n+        assert_eq!(proof.recovered_bytes, payload.len());\n+        assert!(proof.received_symbol_count >= sidecar.source_symbol_count);\n+\n+        let (sidecar_repeat, proof_repeat) =\n+            ft_serialize::generate_raptorq_sidecar(payload, requested_repairs)\n+                .expect(\"successful RaptorQ sidecar generation must be deterministic\");\n+        assert_eq!(sidecar, sidecar_repeat);\n+        assert_eq!(proof, proof_repeat);\n+    }\n+});"
    }
  ]
}
