      "patch": "@@ -929,6 +929,19 @@\n         ]\n       }\n     },\n+    {\n+      \"name\": \"eval_nested_table_assignment_writes_back\",\n+      \"now_ms\": 0,\n+      \"argv\": [\n+        \"EVAL\",\n+        \"local t = { a = { b = 1 } }\\nt.a.b = 42\\nreturn t.a.b\",\n+        \"0\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"integer\",\n+        \"value\": 42\n+      }\n+    },\n     {\n       \"name\": \"eval_string_lower\",\n       \"now_ms\": 0,\n@@ -1382,6 +1395,19 @@\n         \"value\": \"b\"\n       }\n     },\n+    {\n+      \"name\": \"eval_select_negative_index\",\n+      \"now_ms\": 100,\n+      \"argv\": [\n+        \"EVAL\",\n+        \"return select(-1, 'a', 'b', 'c')\",\n+        \"0\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"bulk\",\n+        \"value\": \"c\"\n+      }\n+    },\n     {\n       \"name\": \"eval_type_number\",\n       \"now_ms\": 100,"
