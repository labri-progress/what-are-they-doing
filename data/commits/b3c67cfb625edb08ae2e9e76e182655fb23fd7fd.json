      "patch": "@@ -0,0 +1,40 @@\n+{\n+  \"packet_id\": \"FP-P2D-086\",\n+  \"case_id\": \"series_extract_df_named_groups_strict\",\n+  \"mode\": \"strict\",\n+  \"operation\": \"series_extract_df\",\n+  \"regex_pattern\": \"(?P<prefix>[A-Za-z]+)-(?P<number>\\\\d+)\",\n+  \"left\": {\n+    \"name\": \"strings\",\n+    \"index\": [\n+      { \"kind\": \"utf8\", \"value\": \"row_a\" },\n+      { \"kind\": \"utf8\", \"value\": \"row_b\" },\n+      { \"kind\": \"utf8\", \"value\": \"row_b\" }\n+    ],\n+    \"values\": [\n+      { \"kind\": \"utf8\", \"value\": \"abc-123\" },\n+      { \"kind\": \"utf8\", \"value\": \"xyz\" },\n+      { \"kind\": \"utf8\", \"value\": \"def-456\" }\n+    ]\n+  },\n+  \"expected_frame\": {\n+    \"index\": [\n+      { \"kind\": \"utf8\", \"value\": \"row_a\" },\n+      { \"kind\": \"utf8\", \"value\": \"row_b\" },\n+      { \"kind\": \"utf8\", \"value\": \"row_b\" }\n+    ],\n+    \"column_order\": [\"prefix\", \"number\"],\n+    \"columns\": {\n+      \"prefix\": [\n+        { \"kind\": \"utf8\", \"value\": \"abc\" },\n+        { \"kind\": \"null\", \"value\": \"na_n\" },\n+        { \"kind\": \"utf8\", \"value\": \"def\" }\n+      ],\n+      \"number\": [\n+        { \"kind\": \"utf8\", \"value\": \"123\" },\n+        { \"kind\": \"null\", \"value\": \"na_n\" },\n+        { \"kind\": \"utf8\", \"value\": \"456\" }\n+      ]\n+    }\n+  }\n+}"
