      "raw_url": "https://github.com/teamchong/textsift/raw/696732e88119c82f5f972a4852caa7b80ebba1a9/tests%2Fconformance%2Fshaders.html",
      "contents_url": "https://api.github.com/repos/teamchong/textsift/contents/tests%2Fconformance%2Fshaders.html?ref=696732e88119c82f5f972a4852caa7b80ebba1a9",
      "patch": "@@ -244,6 +244,68 @@\n             };\n           },\n         },\n+        {\n+          name: \"embed_lookup_int4\",\n+          build() {\n+            const T = 4, V = 32, D = 128;\n+            const n_blocks = D / 32;\n+            const ids = new Int32Array(T);\n+            const idsRng = makeRng(40);\n+            for (let i = 0; i < T; i++) ids[i] = Math.floor((idsRng() + 1) * 0.5 * V);\n+            const wNib = rngNibbles(41, V * D);\n+            const w_int4 = packNibbles(wNib);\n+            const scales = rngF16(42, V * n_blocks, 1.0);\n+            const w_zp = packZp(V, n_blocks, 43);\n+            return {\n+              uniform: { binding: 0, bytes: dimsBuf([{tag:\"u32\",value:T},{tag:\"u32\",value:V},{tag:\"u32\",value:D},{tag:\"u32\",value:0}]) },\n+              inputs: [\n+                { binding: 1, name: \"embed_int4\", bytes: w_int4 },\n+                { binding: 2, name: \"embed_scales\", bytes: scales },\n+                { binding: 3, name: \"embed_zp\", bytes: w_zp },\n+                { binding: 4, name: \"ids\", bytes: new Uint8Array(ids.buffer) },\n+              ],\n+              output: { binding: 5, elements: T * D, dtype: \"f16\" },\n+              dispatch: [Math.ceil(T * D / 64), 1, 1],\n+            };\n+          },\n+        },\n+        {\n+          name: \"add_rmsnorm_fp16_to_f32\",\n+          build() {\n+            const T = 4, D = 128, eps = 1e-6;\n+            return {\n+              uniform: { binding: 0, bytes: dimsBuf([{tag:\"u32\",value:T},{tag:\"u32\",value:D},{tag:\"f32\",value:eps},{tag:\"u32\",value:0}]) },\n+              inputs: [\n+                { binding: 1, name: \"a\", bytes: rngF16(50, T*D, 0.5) },\n+                { binding: 2, name: \"b\", bytes: rngF16(51, T*D, 0.5) },\n+                { binding: 3, name: \"gamma\", bytes: rngF16(52, D, 1.0) },\n+                // sum_out (binding 4) is a secondary writable output;\n+                // hand it a zero-filled buffer so the shader can write\n+                // to it. We don't read it back \u2014 primary output is\n+                // norm_out at binding 5.\n+                { binding: 4, name: \"_sum_out_init\", bytes: new Uint8Array(T * D * 2) },\n+              ],\n+              output: { binding: 5, elements: T * D, dtype: \"f32\" },\n+              dispatch: [T, 1, 1],\n+            };\n+          },\n+        },\n+        {\n+          name: \"router_topk\",\n+          build() {\n+            const T = 4, E = 16, K = 4;\n+            return {\n+              uniform: { binding: 0, bytes: dimsBuf([{tag:\"u32\",value:T},{tag:\"u32\",value:E},{tag:\"u32\",value:K},{tag:\"u32\",value:0}]) },\n+              inputs: [\n+                { binding: 1, name: \"logits\", bytes: new Uint8Array(rngF32(60, T * E, 2.0).buffer) },\n+                // out_idx is the secondary output (i32), zero-filled.\n+                { binding: 2, name: \"_out_idx_init\", bytes: new Uint8Array(T * K * 4) },\n+              ],\n+              output: { binding: 3, elements: T * K, dtype: \"f32\" },\n+              dispatch: [Math.ceil(T / 64), 1, 1],\n+            };\n+          },\n+        },\n         {\n           name: \"matmul_int4_f32_f32\",\n           build() {"
    },
