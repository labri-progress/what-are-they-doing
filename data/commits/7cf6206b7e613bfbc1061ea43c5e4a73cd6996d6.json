      "patch": "@@ -0,0 +1,35 @@\n+{\n+  \"packet_id\": \"FP-P2D-165\",\n+  \"case_id\": \"dataframe_head_zero_n_strict\",\n+  \"mode\": \"strict\",\n+  \"operation\": \"dataframe_head\",\n+  \"frame\": {\n+    \"index\": [\n+      { \"kind\": \"utf8\", \"value\": \"dup\" },\n+      { \"kind\": \"utf8\", \"value\": \"dup\" },\n+      { \"kind\": \"utf8\", \"value\": \"x\" }\n+    ],\n+    \"column_order\": [\"b\", \"a\"],\n+    \"columns\": {\n+      \"b\": [\n+        { \"kind\": \"int64\", \"value\": 10 },\n+        { \"kind\": \"int64\", \"value\": 20 },\n+        { \"kind\": \"int64\", \"value\": 30 }\n+      ],\n+      \"a\": [\n+        { \"kind\": \"float64\", \"value\": 1.5 },\n+        { \"kind\": \"float64\", \"value\": -2.5 },\n+        { \"kind\": \"float64\", \"value\": 3.5 }\n+      ]\n+    }\n+  },\n+  \"head_n\": 0,\n+  \"expected_frame\": {\n+    \"index\": [],\n+    \"column_order\": [\"b\", \"a\"],\n+    \"columns\": {\n+      \"b\": [],\n+      \"a\": []\n+    }\n+  }\n+}"
