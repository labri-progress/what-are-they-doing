    {
      "sha": "258902acb673cceaa686f2a31e041688b0a7813b",
      "filename": "fuzz/fuzz_targets/ft_dispatch_schema_parser.rs",
      "status": "added",
      "additions": 55,
      "deletions": 0,
      "changes": 55,
      "blob_url": "https://github.com/Dicklesworthstone/frankentorch/blob/8824dfce42064532029b9a3c6306e7f61d2953b0/fuzz%2Ffuzz_targets%2Fft_dispatch_schema_parser.rs",
      "raw_url": "https://github.com/Dicklesworthstone/frankentorch/raw/8824dfce42064532029b9a3c6306e7f61d2953b0/fuzz%2Ffuzz_targets%2Fft_dispatch_schema_parser.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankentorch/contents/fuzz%2Ffuzz_targets%2Fft_dispatch_schema_parser.rs?ref=8824dfce42064532029b9a3c6306e7f61d2953b0",
      "patch": "@@ -0,0 +1,55 @@\n+#![no_main]\n+\n+use ft_dispatch::{\n+    ParsedSchemaInput, parse_schema_name, parse_schema_or_name, schema_dispatch_key_from_tag,\n+    schema_dispatch_keyset_from_tags,\n+};\n+use libfuzzer_sys::fuzz_target;\n+\n+const MAX_SCHEMA_INPUT_BYTES: usize = 8 * 1024;\n+\n+fuzz_target!(|data: &[u8]| {\n+    if data.len() > MAX_SCHEMA_INPUT_BYTES {\n+        return;\n+    }\n+\n+    let Ok(input) = std::str::from_utf8(data) else {\n+        return;\n+    };\n+\n+    let name_result = parse_schema_name(input);\n+    let schema_result = parse_schema_or_name(input);\n+\n+    if let Ok(ParsedSchemaInput::Name(parsed)) = &schema_result {\n+        assert_eq!(\n+            name_result.as_ref(),\n+            Ok(parsed),\n+            \"name-only schema parsing must agree with direct name parsing\"\n+        );\n+    }\n+\n+    if let Ok(ParsedSchemaInput::Schema(schema)) = &schema_result {\n+        assert!(\n+            !schema.arguments.contains(\") ->\"),\n+            \"arguments should be split before the return separator\"\n+        );\n+        assert!(\n+            !schema.returns.is_empty(),\n+            \"successful full schema parse must keep a non-empty return declaration\"\n+        );\n+    }\n+\n+    for tag in input\n+        .split([',', '|', ' ', '\\n', '\\t'])\n+        .filter(|tag| !tag.is_empty())\n+    {\n+        let _ = schema_dispatch_key_from_tag(tag);\n+    }\n+\n+    let tags = input\n+        .split([',', '|', ' ', '\\n', '\\t'])\n+        .filter(|tag| !tag.is_empty())\n+        .take(8)\n+        .collect::<Vec<_>>();\n+    let _ = schema_dispatch_keyset_from_tags(&tags);\n+});"
    }
  ]
