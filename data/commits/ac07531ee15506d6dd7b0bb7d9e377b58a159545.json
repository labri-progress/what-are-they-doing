{
  "message": "Remove flaky y timing measurement from every transformation test\n\nThe y field measured now() slightly after x was computed, making it\nsusceptible to crossing a second boundary on slow CI machines. The x\nfield already validates the every operator's timing behavior.",
  "files": [
    {
      "sha": "8bca0a704c773a930a3f03afc5c5b1b16c5f775c",
      "filename": "test/tests/operators/every/transformation.tql",
      "status": "modified",
      "additions": 0,
      "deletions": 1,
      "changes": 1,
      "blob_url": "https://github.com/tenzir/tenzir/blob/ac07531ee15506d6dd7b0bb7d9e377b58a159545/test%2Ftests%2Foperators%2Fevery%2Ftransformation.tql",
      "raw_url": "https://github.com/tenzir/tenzir/raw/ac07531ee15506d6dd7b0bb7d9e377b58a159545/test%2Ftests%2Foperators%2Fevery%2Ftransformation.tql",
      "contents_url": "https://api.github.com/repos/tenzir/tenzir/contents/test%2Ftests%2Foperators%2Fevery%2Ftransformation.tql?ref=ac07531ee15506d6dd7b0bb7d9e377b58a159545",
      "patch": "@@ -5,6 +5,5 @@ every 750ms {\n every 1s {\n   let $started = now()\n   x = ($started - $parent).round(1s)\n-  y = (now() - $parent).round(1s)\n }\n head 4"
    },
    {
      "sha": "1766080a9cd0bc52fa962b1725d77392e89b5fa2",
      "filename": "test/tests/operators/every/transformation.txt",
      "status": "modified",
      "additions": 0,
      "deletions": 4,
      "changes": 4,
      "blob_url": "https://github.com/tenzir/tenzir/blob/ac07531ee15506d6dd7b0bb7d9e377b58a159545/test%2Ftests%2Foperators%2Fevery%2Ftransformation.txt",
      "raw_url": "https://github.com/tenzir/tenzir/raw/ac07531ee15506d6dd7b0bb7d9e377b58a159545/test%2Ftests%2Foperators%2Fevery%2Ftransformation.txt",
      "contents_url": "https://api.github.com/repos/tenzir/tenzir/contents/test%2Ftests%2Foperators%2Fevery%2Ftransformation.txt?ref=ac07531ee15506d6dd7b0bb7d9e377b58a159545",
      "patch": "@@ -1,16 +1,12 @@\n {\n   x: 0ns,\n-  y: 0ns,\n }\n {\n   x: 0ns,\n-  y: 1s,\n }\n {\n   x: 1s,\n-  y: 2s,\n }\n {\n   x: 2s,\n-  y: 2s,\n }"
    }
  ]
