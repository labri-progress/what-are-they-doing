.json\",\n+      \"crates/fnp-datetime/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"datetime_adversarial_mul_zero\",\n+    \"delta_unit\": \"h\",\n+    \"delta_value\": 24,\n+    \"multiplier\": 0,\n+    \"expected_behavior\": \"zero_timedelta\"\n+  },\n+  {\n+    \"id\": \"datetime_sub_same\",\n+    \"operation\": \"datetime_sub\",\n+    \"seed\": 12212,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-datetime-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/datetime_adversarial_cases.json\",\n+      \"crates/fnp-datetime/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"datetime_adversarial_sub_same\",\n+    \"datetime_a\": \"2024-06-15T12:00:00\",\n+    \"datetime_b\": \"2024-06-15T12:00:00\",\n+    \"expected_behavior\": \"zero_timedelta\"\n+  }\n+]"
