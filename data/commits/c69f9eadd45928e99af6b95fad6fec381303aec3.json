      "patch": "@@ -0,0 +1,185 @@\n+[\n+  {\n+    \"id\": \"datetime_nat_arithmetic\",\n+    \"operation\": \"datetime_add\",\n+    \"seed\": 12201,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-datetime-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/datetime_adversarial_cases.json\",\n+      \"crates/fnp-datetime/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"datetime_adversarial_nat_propagation\",\n+    \"base_datetime\": \"NaT\",\n+    \"delta_unit\": \"D\",\n+    \"delta_value\": 5,\n+    \"expected_behavior\": \"nat_result\"\n+  },\n+  {\n+    \"id\": \"timedelta_nat_arithmetic\",\n+    \"operation\": \"timedelta_add\",\n+    \"seed\": 12202,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-datetime-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/datetime_adversarial_cases.json\",\n+      \"crates/fnp-datetime/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"datetime_adversarial_timedelta_nat\",\n+    \"delta_a\": \"NaT\",\n+    \"delta_b_unit\": \"h\",\n+    \"delta_b_value\": 24,\n+    \"expected_behavior\": \"nat_result\"\n+  },\n+  {\n+    \"id\": \"datetime_compare_with_nat\",\n+    \"operation\": \"datetime_compare\",\n+    \"seed\": 12203,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-datetime-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/datetime_adversarial_cases.json\",\n+      \"crates/fnp-datetime/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"datetime_adversarial_nat_compare\",\n+    \"datetime_a\": \"2024-06-15T12:00:00\",\n+    \"datetime_b\": \"NaT\",\n+    \"expected_behavior\": \"comparison_with_nat\"\n+  },\n+  {\n+    \"id\": \"datetime_zero_timedelta\",\n+    \"operation\": \"datetime_add\",\n+    \"seed\": 12204,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-datetime-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/datetime_adversarial_cases.json\",\n+      \"crates/fnp-datetime/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"datetime_adversarial_zero_delta\",\n+    \"base_datetime\": \"2024-06-15T12:00:00\",\n+    \"delta_unit\": \"D\",\n+    \"delta_value\": 0,\n+    \"expected_datetime\": \"2024-06-15T12:00:00\"\n+  },\n+  {\n+    \"id\": \"timedelta_negative_large\",\n+    \"operation\": \"timedelta_create\",\n+    \"seed\": 12205,\n+    \"mode\": \"hardened\",\n+    \"env_fingerprint\": \"fnp-datetime-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/datetime_adversarial_cases.json\",\n+      \"crates/fnp-datetime/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"datetime_adversarial_large_negative\",\n+    \"delta_unit\": \"D\",\n+    \"delta_value\": -365000,\n+    \"expected_behavior\": \"valid_negative_delta\"\n+  },\n+  {\n+    \"id\": \"datetime_epoch_boundary\",\n+    \"operation\": \"datetime_create\",\n+    \"seed\": 12206,\n+    \"mode\": \"strict\",\n+    \"env_fingerprint\": \"fnp-datetime-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/datetime_adversarial_cases.json\",\n+      \"crates/fnp-datetime/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"datetime_adversarial_epoch\",\n+    \"datetime\": \"1970-01-01T00:00:00\",\n+    \"expected_behavior\": \"unix_epoch\"\n+  },\n+  {\n+    \"id\": \"datetime_year_2038_boundary\",\n+    \"operation\": \"datetime_create\",\n+    \"seed\": 12207,\n+    \"mode\": \"hardened\",\n+    \"env_fingerprint\": \"fnp-datetime-adversarial-packet-f\",\n+    \"artifact_refs\": [\n+      \"crates/fnp-conformance/fixtures/datetime_adversarial_cases.json\",\n+      \"crates/fnp-datetime/src/lib.rs\"\n+    ],\n+    \"reason_code\": \"datetime_adversarial_y2038\",\n+    \"datetime\": \"2038-01-19T03:14:08\",\n+    \"expected_behavior\": \"valid_datetime\"\n+  },\n+  {\n+    \"id\": \"datetime_leap_second_boundary\",\n+    \"operation\": \"datetim