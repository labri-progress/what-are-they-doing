{
  "message": "fix(ci): add rustfmt+clippy components to pinned toolchain and beads_rust clone\n\nrust-toolchain.toml pinned nightly-2026-02-13 but didn't list components,\nso cargo fmt/clippy failed with \"'cargo-fmt' is not installed for the\ntoolchain nightly-2026-02-13\".\n\nAlso adds beads_rust to the sibling clone list (was missing, causing\n\"failed to load source for dependency beads_rust\").\n\nBump to v0.2.24.\n\nCo-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>",
  "files": [
    {
      "sha": "f1b49a9f6ccde38556f00c1fd95101de0b9a2013",
      "filename": "Cargo.toml",
      "status": "modified",
      "additions": 1,
      "deletions": 1,
      "changes": 2,
      "blob_url": "https://github.com/Dicklesworthstone/mcp_agent_mail_rust/blob/f3d3c26e49223a012d4ce2f42b579298d03d5cfa/Cargo.toml",
      "raw_url": "https://github.com/Dicklesworthstone/mcp_agent_mail_rust/raw/f3d3c26e49223a012d4ce2f42b579298d03d5cfa/Cargo.toml",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/mcp_agent_mail_rust/contents/Cargo.toml?ref=f3d3c26e49223a012d4ce2f42b579298d03d5cfa",
      "patch": "@@ -16,7 +16,7 @@ members = [\n ]\n \n [workspace.package]\n-version = \"0.2.23\"\n+version = \"0.2.24\"\n edition = \"2024\"\n license = \"LicenseRef-MIT-Rider\"\n license-file = \"LICENSE\""
    },
    {
      "sha": "78c8f0104ccba79499d552809104128f4f62a4ef",
      "filename": "rust-toolchain.toml",
      "status": "modified",
      "additions": 1,
      "deletions": 0,
      "changes": 1,
      "blob_url": "https://github.com/Dicklesworthstone/mcp_agent_mail_rust/blob/f3d3c26e49223a012d4ce2f42b579298d03d5cfa/rust-toolchain.toml",
      "raw_url": "https://github.com/Dicklesworthstone/mcp_agent_mail_rust/raw/f3d3c26e49223a012d4ce2f42b579298d03d5cfa/rust-toolchain.toml",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/mcp_agent_mail_rust/contents/rust-toolchain.toml?ref=f3d3c26e49223a012d4ce2f42b579298d03d5cfa",
      "patch": "@@ -1,2 +1,3 @@\n [toolchain]\n channel = \"nightly-2026-02-13\"\n+components = [\"rustfmt\", \"clippy\"]"
    }
  ]
