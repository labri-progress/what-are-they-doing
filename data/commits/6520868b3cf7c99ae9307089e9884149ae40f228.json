      "raw_url": "https://github.com/kubestellar/console/raw/6520868b3cf7c99ae9307089e9884149ae40f228/web%2Ftsconfig.json",
      "contents_url": "https://api.github.com/repos/kubestellar/console/contents/web%2Ftsconfig.json?ref=6520868b3cf7c99ae9307089e9884149ae40f228",
