      "contents_url": "https://api.github.com/repos/kubestellar/console/contents/web%2Fpackage.json?ref=6520868b3cf7c99ae9307089e9884149ae40f228",
      "patch": "@@ -120,7 +120,7 @@\n     \"rimraf\": \"^6.1.3\",\n     \"storybook\": \"^10.3.5\",\n     \"tailwindcss\": \"^4.2.4\",\n-    \"typescript\": \"^6.0.3\",\n+    \"typescript\": \"~6.0.3\",\n     \"typescript-eslint\": \"^8.58.2\",\n     \"vite\": \"^8.0.5\",\n     \"vite-plugin-compression2\": \"^2.5.3\","
    },
    {
