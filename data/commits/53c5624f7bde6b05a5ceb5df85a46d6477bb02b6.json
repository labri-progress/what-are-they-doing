      "blob_url": "https://github.com/Dicklesworthstone/franken_networkx/blob/53c5624f7bde6b05a5ceb5df85a46d6477bb02b6/crates%2Ffnx-algorithms%2Fsrc%2Flib.rs",
      "raw_url": "https://github.com/Dicklesworthstone/franken_networkx/raw/53c5624f7bde6b05a5ceb5df85a46d6477bb02b6/crates%2Ffnx-algorithms%2Fsrc%2Flib.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/franken_networkx/contents/crates%2Ffnx-algorithms%2Fsrc%2Flib.rs?ref=53c5624f7bde6b05a5ceb5df85a46d6477bb02b6",
      "patch": "@@ -16694,6 +16694,7 @@ fn local_node_connectivity_bfs(graph: &Graph, s: &str, t: &str) -> usize {\n \n     let mut flow = 0;\n     let mut excluded: HashSet<&str> = HashSet::new();\n+    let mut direct_edge_used = false;\n \n     loop {\n         // BFS from s to t avoiding excluded nodes (except s and t)\n@@ -16711,6 +16712,10 @@ fn local_node_connectivity_bfs(graph: &Graph, s: &str, t: &str) -> usize {\n             }\n             if let Some(nbrs) = graph.neighbors_iter(curr) {\n                 for nbr in nbrs {\n+                    // Skip the direct s->t edge if already used\n+                    if curr == s && nbr == t && direct_edge_used {\n+                        continue;\n+                    }\n                     if !visited.contains(nbr) && (nbr == t || !excluded.contains(nbr)) {\n                         visited.insert(nbr);\n                         parent.insert(nbr, curr);\n@@ -16725,14 +16730,22 @@ fn local_node_connectivity_bfs(graph: &Graph, s: &str, t: &str) -> usize {\n         }\n \n         // Trace path and exclude internal nodes\n+        let mut path_len = 0usize;\n         let mut node = t;\n         while let Some(&p) = parent.get(node) {\n             if node != s && node != t {\n                 excluded.insert(node);\n             }\n+            path_len += 1;\n             node = p;\n         }\n         flow += 1;\n+\n+        // If this was a direct edge (path length 1), mark it used so\n+        // we don't re-discover the same direct edge and loop forever.\n+        if path_len == 1 {\n+            direct_edge_used = true;\n+        }\n     }\n     flow\n }"
    },
