      "raw_url": "https://github.com/Dicklesworthstone/flywheel_connectors/raw/12667e02252269be7a9db3cbbbafc9bf164f12a8/crates%2Ffcp-conformance%2Fsrc%2Fvectors%2Fcapability.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/flywheel_connectors/contents/crates%2Ffcp-conformance%2Fsrc%2Fvectors%2Fcapability.rs?ref=12667e02252269be7a9db3cbbbafc9bf164f12a8",
      "patch": "@@ -90,14 +90,17 @@ impl CapabilityTokenGoldenVector {\n             expires: 1_700_086_400,\n             // RFC 8949 canonical CBOR map-key order: positives first\n             // (by value), then negatives by ascending N = -1-key.\n-            // Regenerated after 6df66c79 switched the encoder from\n-            // numeric-i64 ordering to RFC 8949 bytewise lex (br-b6rtk).\n-            // The `expected_claims_cbor` reflects raw CwtClaims::to_cbor\n-            // (8 entries) BEFORE `CoseToken::sign` synthesizes the\n-            // current SCHEMA_VERSION; `expected_token_cbor` reflects the\n-            // signed payload AFTER synthesis (9 entries).\n+            // Regenerated twice:\n+            //   * 6df66c79 \u2014 encoder switched to RFC 8949 bytewise lex (br-b6rtk).\n+            //   * c828a3e7 \u2014 principal_zone synthesized at CWT key 3 by\n+            //     `CoseToken::sign` (\"add principal zone access floor\");\n+            //     expected_token_cbor regen closes br-lobrq.\n+            // `expected_claims_cbor` reflects raw CwtClaims::to_cbor (8\n+            // entries) BEFORE sign synthesizes SCHEMA_VERSION (key -16)\n+            // and principal_zone (key 3). `expected_token_cbor` reflects\n+            // the signed payload AFTER synthesis (10 entries = 8 + 2).\n             expected_claims_cbor: \"a8016c6e6f64653a7072696d617279041a65554280051a6553f1003a00010000706361703a646973636f72642e73656e643a00010001667a3a776f726b3a000100028174646973636f72642e73656e645f6d6573736167653a000100036c6167656e743a636c617564653a0001000678186e6f64653a7072696d6172792e6d6573682e74732e6e6574\".into(),\n-            expected_token_cbor: \"\".into(),\n+            expected_token_cbor: \"\".into(),\n         }\n     }\n \n@@ -124,8 +127,12 @@ impl CapabilityTokenGoldenVector {\n             checkpoint_seq: Some(42),\n             not_before: 1_700_000_000,\n             expires: 1_700_172_800,\n+            // expected_token_cbor regenerated after c828a3e7 (principal_zone at\n+            // CWT key 3 synthesized by CoseToken::sign). Raw claims CBOR\n+            // unchanged \u2014 principal_zone is sign-time synthesis, not a\n+            // CwtClaims field. (br-lobrq)\n             expected_claims_cbor: \"\".into(),\n-            expected_token_cbor: \"\".into(),\n+            expected_token_cbor: \"\".into(),\n         }\n     }\n \n@@ -157,8 +164,10 @@ impl CapabilityTokenGoldenVector {\n             checkpoint_seq: None,\n             not_before: 1_700_000_000,\n             expires: 1_700_003_600,\n+            // expected_token_cbor regenerated after c828a3e7 (sign-time\n+            // principal_zone synthesis). Raw claims unchanged. (br-lobrq)\n             expected_claims_cbor: \"\".into(),\n-            expected_token_cbor: \"\".into(),\n+            expected_token_cbor: \"\".into(),\n         }\n     }\n "
