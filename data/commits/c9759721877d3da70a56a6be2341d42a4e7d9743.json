      "deletions": 0,
      "changes": 24,
      "blob_url": "https://github.com/Dicklesworthstone/frankenredis/blob/c9759721877d3da70a56a6be2341d42a4e7d9743/fuzz%2Ffuzz_targets%2Ffuzz_resp_roundtrip.rs",
      "raw_url": "https://github.com/Dicklesworthstone/frankenredis/raw/c9759721877d3da70a56a6be2341d42a4e7d9743/fuzz%2Ffuzz_targets%2Ffuzz_resp_roundtrip.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankenredis/contents/fuzz%2Ffuzz_targets%2Ffuzz_resp_roundtrip.rs?ref=c9759721877d3da70a56a6be2341d42a4e7d9743",
      "patch": "@@ -0,0 +1,24 @@\n+#![no_main]\n+\n+use libfuzzer_sys::fuzz_target;\n+\n+use fr_protocol::parse_frame;\n+\n+fuzz_target!(|data: &[u8]| {\n+    // Guard against excessively large inputs\n+    if data.len() > 1_000_000 {\n+        return;\n+    }\n+\n+    // Round-trip oracle: if we can parse it, encoding and re-parsing must yield same frame\n+    if let Ok(parsed) = parse_frame(data) {\n+        let encoded = parsed.frame.to_bytes();\n+        let reparsed = parse_frame(&encoded)\n+            .expect(\"re-encoding a parsed frame must be parseable\");\n+\n+        assert_eq!(\n+            parsed.frame, reparsed.frame,\n+            \"Round-trip violation: parse(encode(frame)) != frame\"\n+        );\n+    }\n+});"
    }
  ]
