      "patch": "@@ -0,0 +1,15 @@\n+#![no_main]\n+\n+use libfuzzer_sys::fuzz_target;\n+\n+use fr_persist::decode_aof_stream;\n+\n+fuzz_target!(|data: &[u8]| {\n+    // Guard against excessively large inputs\n+    if data.len() > 10_000_000 {\n+        return;\n+    }\n+\n+    // AOF decoder should never panic on any input\n+    let _ = decode_aof_stream(data);\n+});"
