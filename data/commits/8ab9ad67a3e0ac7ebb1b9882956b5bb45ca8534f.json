      "patch": "@@ -0,0 +1,18 @@\n+{\n+  \"name\": \"klaude\",\n+  \"description\": \"AI-powered multi-cluster Kubernetes management. Discover clusters, check health, analyze RBAC, manage OPA Gatekeeper policies, check for upgrades, and troubleshoot issues across all your Kubernetes clusters.\",\n+  \"version\": \"0.6.0\",\n+  \"author\": {\n+    \"name\": \"KubeStellar\",\n+    \"url\": \"https://github.com/kubestellar/klaude\"\n+  },\n+  \"repository\": \"https://github.com/kubestellar/klaude\",\n+  \"keywords\": [\"kubernetes\", \"k8s\", \"multi-cluster\", \"rbac\", \"kubectl\", \"devops\", \"infrastructure\", \"gatekeeper\", \"opa\", \"upgrades\"],\n+  \"mcpServers\": {\n+    \"klaude\": {\n+      \"command\": \"/opt/homebrew/bin/klaude\",\n+      \"args\": [\"--mcp-server\"],\n+      \"description\": \"Multi-cluster Kubernetes MCP server with 37 tools for cluster management, diagnostics, RBAC analysis, OPA Gatekeeper policy management, and upgrade management\"\n+    }\n+  }\n+}"
