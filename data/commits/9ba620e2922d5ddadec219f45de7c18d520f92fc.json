 \"result_dtype\": \"float16\",\n+      \"result_value\": 2.5,\n+      \"rhs_dtype\": \"bool\"\n+    },\n+    {\n+      \"case_id\": \"mul_f16_i32\",\n+      \"lhs_dtype\": \"f16\",\n+      \"operation\": \"mul\",\n+      \"result_dtype\": \"float16\",\n+      \"result_value\": 17.5,\n+      \"rhs_dtype\": \"i32\"\n+    },\n+    {\n+      \"case_id\": \"mul_f16_i64\",\n+      \"lhs_dtype\": \"f16\",\n+      \"operation\": \"mul\",\n+      \"result_dtype\": \"float16\",\n+      \"result_value\": 17.5,\n+      \"rhs_dtype\": \"i64\"\n+    },\n+    {\n+      \"case_id\": \"mul_f16_u32\",\n+      \"lhs_dtype\": \"f16\",\n+      \"operation\": \"mul\",\n+      \"result_dtype\": \"float16\",\n+      \"result_value\": 17.5,\n+      \"rhs_dtype\": \"u32\"\n+    },\n+    {\n+      \"case_id\": \"mul_f16_u64\",\n+      \"lhs_dtype\": \"f16\",\n+      \"operation\": \"mul\",\n+      \"result_dtype\": \"float16\",\n+      \"result_value\": 17.5,\n+      \"rhs_dtype\": \"u64\"\n+    },\n+    {\n+      \"case_id\": \"mul_f16_f32\",\n+      \"lhs_dtype\": \"f16\",\n+      \"operation\": \"mul\",\n+      \"result_dtype\": \"float32\",\n+      \"result_value\": 6.25,\n+      \"rhs_dtype\": \"f32\"\n+    },\n+    {\n+      \"case_id\": \"mul_f16_f64\",\n+      \"lhs_dtype\": \"f16\",\n+      \"operation\": \"mul\",\n+      \"result_dtype\": \"float64\",\n+      \"result_value\": 6.25,\n+      \"rhs_dtype\": \"f64\"\n+    },\n+    {\n+      \"case_id\": \"mul_f16_bf16\",\n+      \"lhs_dtype\": \"f16\",\n+      \"operation\": \"mul\",\n+      \"result_dtype\": \"float32\",\n+      \"result_value\": 6.25,\n+      \"rhs_dtype\": \"bf16\"\n+    },\n+    {\n+      \"case_id\": \"mul_f16_f16\",\n+      \"lhs_dtype\": \"f16\",\n+      \"operation\": \"mul\",\n+      \"result_dtype\": \"float16\",\n+      \"result_value\": 6.25,\n+      \"rhs_dtype\": \"f16\"\n+    }\n+  ],\n+  \"generated_at_unix_ms\": 1773726283855,\n+  \"generated_by\": \"jax_dtype_promotion_oracle\",\n+  \"jax_version\": 