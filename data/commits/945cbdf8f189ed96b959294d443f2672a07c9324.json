      "patch": "@@ -13275,8 +13275,25 @@ pub unsafe extern ¥"C¥" fn gethostbyname2_r(¥n     // Fill result_buf from first addrinfo result¥n     if !res.is_null() {¥n         let ai = unsafe { &*res };¥n-        let addr_len: usize = if af == libc::AF_INET { 4 } else { 16 };¥n-        let needed = addr_len + std::mem::size_of::<*mut c_char>() * 2;¥n+        let addr_len: usize = if ai.ai_family == libc::AF_INET { 4 } else { 16 };¥n+        let name_bytes = if !ai.ai_canonname.is_null() {¥n+            unsafe { CStr::from_ptr(ai.ai_canonname) }.to_bytes()¥n+        } else {¥n+            unsafe { CStr::from_ptr(name) }.to_bytes()¥n+        };¥n+        let ptr_size = core::mem::size_of::<*mut c_char>();¥n+        let addr_align = if ai.ai_family == libc::AF_INET {¥n+            core::mem::align_of::<libc::in_addr>()¥n+        } else {¥n+            core::mem::align_of::<libc::in6_addr>()¥n+        };¥n+        let name_end = name_bytes.len() + 1;¥n+        let addr_off = (name_end + (addr_align - 1)) & !(addr_align - 1);¥n+        let addr_end = addr_off + addr_len;¥n+        let list_off = (addr_end + (ptr_size - 1)) & !(ptr_size - 1);¥n+        let addr_list_off = list_off;¥n+        let alias_list_off = addr_list_off + 2 * ptr_size;¥n+        let needed = alias_list_off + ptr_size;¥n         if buflen < needed {¥n             unsafe {¥n                 crate::resolv_abi::freeaddrinfo(res);¥n@@ -13286,28 +13303,30 @@ pub unsafe extern ¥"C¥" fn gethostbyname2_r(¥n             return libc::ERANGE;¥n         }¥n         unsafe {¥n-            // Copy address into buf¥n+            let buf_u8 = buf as *mut u8;¥n+            std::ptr::copy_nonoverlapping(name_bytes.as_ptr(), buf_u8, name_bytes.len());¥n+            *buf_u8.add(name_bytes.len()) = 0;¥n+¥n+            // Copy address into caller buffer after the packed hostname.¥n             let addr_ptr = if af == libc::AF_INET {¥n                 let sa = ai.ai_addr as *const libc::sockaddr_in;¥n                 &(*sa).sin_addr as *const _ as *const u8¥n             } else {¥n                 let sa = ai.ai_addr as *const libc::sockaddr_in6;¥n                 &(*sa).sin6_addr as *const _ as *const u8¥n             };¥n-            std::ptr::copy_nonoverlapping(addr_ptr, buf as *mut u8, addr_len);¥n+            std::ptr::copy_nonoverlapping(addr_ptr, buf_u8.add(addr_off), addr_len);¥n ¥n-            // Set up address list in buf after the address¥n-            let addr_list_ptr = buf.add(addr_len) as *mut *mut c_char;¥n-            *addr_list_ptr = buf;¥n+            // Set up address and alias lists inside the caller buffer.¥n+            let addr_list_ptr = buf_u8.add(addr_list_off) as *mut *mut c_char;¥n+            *addr_list_ptr = buf_u8.add(addr_off) as *mut c_char;¥n             *addr_list_ptr.add(1) = std::ptr::null_mut();¥n+            let alias_list_ptr = buf_u8.add(alias_list_off) as *mut *mut c_char;¥n+            *alias_list_ptr = std::ptr::null_mut();¥n ¥n-            (*result_buf).h_name = if !ai.ai_canonname.is_null() {¥n-                ai.ai_canonname¥n-            } else {¥n-                name as *mut c_char¥n-            };¥n-            (*result_buf).h_aliases = std::ptr::null_mut();¥n-            (*result_buf).h_addrtype = af;¥n+            (*result_buf).h_name = buf;¥n+            (*result_buf).h_aliases = alias_list_ptr;¥n+            (*result_buf).h_addrtype = ai.ai_family;¥n             (*result_buf).h_length = addr_len as c_int;¥n             (*result_buf).h_addr_list = addr_list_ptr;¥n "
