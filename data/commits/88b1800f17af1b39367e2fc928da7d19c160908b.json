      "patch": "@@ -30,6 +30,9 @@ path = \"../../fj-lax\"\n [dependencies.fj-trace]\n path = \"../../fj-trace\"\n \n+[dependencies.fj-interpreters]\n+path = \"../../fj-interpreters\"\n+\n [[bin]]\n name = \"ir_deserializer\"\n path = \"fuzz_targets/ir_deserializer.rs\"\n@@ -107,6 +110,13 @@ test = false\n doc = false\n bench = false\n \n+[[bin]]\n+name = \"partial_eval_fuzzer\"\n+path = \"fuzz_targets/partial_eval_fuzzer.rs\"\n+test = false\n+doc = false\n+bench = false\n+\n # Keep fuzzing package separate from the workspace package graph.\n [workspace]\n members = [\".\"]"
