{
  "message": "\ud83d\udc1b Add macOS network.client entitlement for outbound connections\n\nmacOS App Sandbox was blocking all outbound HTTP requests, causing\nSocketException on provider refresh. Added network.client entitlement\nto both DebugProfile and Release entitlements.\n\nSigned-off-by: Andrew Anderson <andy@clubanderson.com>",
  "files": [
    {
      "sha": "08c3ab17cc263a50bd1d67b108c0689c69e7aba8",
      "filename": "macos/Runner/DebugProfile.entitlements",
      "status": "modified",
      "additions": 2,
      "deletions": 0,
      "changes": 2,
      "blob_url": "https://github.com/clubanderson/clubTivi/blob/573b07a874dba21e1c37810b5058174344c6c5c9/macos%2FRunner%2FDebugProfile.entitlements",
      "raw_url": "https://github.com/clubanderson/clubTivi/raw/573b07a874dba21e1c37810b5058174344c6c5c9/macos%2FRunner%2FDebugProfile.entitlements",
      "contents_url": "https://api.github.com/repos/clubanderson/clubTivi/contents/macos%2FRunner%2FDebugProfile.entitlements?ref=573b07a874dba21e1c37810b5058174344c6c5c9",
      "patch": "@@ -8,5 +8,7 @@\n \t<true/>\n \t<key>com.apple.security.network.server</key>\n \t<true/>\n+\t<key>com.apple.security.network.client</key>\n+\t<true/>\n </dict>\n </plist>"
    },
    {
      "sha": "7a2230dc331daf312fe2ca6bcc81540bd5baa215",
      "filename": "macos/Runner/Release.entitlements",
      "status": "modified",
