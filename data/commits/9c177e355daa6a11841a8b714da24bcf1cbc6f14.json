      "status": "modified",
      "additions": 49,
      "deletions": 0,
      "changes": 49,
      "blob_url": "https://github.com/Dicklesworthstone/frankenredis/blob/9c177e355daa6a11841a8b714da24bcf1cbc6f14/crates%2Ffr-persist%2Fsrc%2Flib.rs",
      "raw_url": "https://github.com/Dicklesworthstone/frankenredis/raw/9c177e355daa6a11841a8b714da24bcf1cbc6f14/crates%2Ffr-persist%2Fsrc%2Flib.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankenredis/contents/crates%2Ffr-persist%2Fsrc%2Flib.rs?ref=9c177e355daa6a11841a8b714da24bcf1cbc6f14",
      "patch": "@@ -3200,6 +3200,55 @@ mod tests {\n         );\n     }\n \n+    #[test]\n+    fn aof_manifest_fuzz_corpus_seeds_parse_or_reject_cleanly()\n+    -> Result<(), Box<dyn std::error::Error>> {\n+        let corpus_root = std::path::Path::new(env!(\"CARGO_MANIFEST_DIR\"))\n+            .join(\"../../fuzz/corpus/fuzz_aof_manifest_parser\");\n+        assert!(\n+            corpus_root.exists(),\n+            \"fuzz corpus dir {} not present\",\n+            corpus_root.display()\n+        );\n+\n+        let mut seed_paths = std::fs::read_dir(&corpus_root)\n+            .map_err(|err| format!(\"read corpus dir {}: {err}\", corpus_root.display()))?\n+            .map(|entry| entry.map(|entry| entry.path()))\n+            .collect::<Result<Vec<_>, _>>()?;\n+        seed_paths.sort();\n+        seed_paths.retain(|path| path.is_file());\n+        assert!(\n+            seed_paths.len() >= 10,\n+            \"expected at least 10 AOF manifest parser fuzz seeds, found {}\",\n+            seed_paths.len()\n+        );\n+\n+        for path in seed_paths {\n+            let bytes = std::fs::read(&path)\n+                .map_err(|err| format!(\"read seed {}: {err}\", path.display()))?;\n+            if bytes.len() > 1_000_000 {\n+                continue;\n+            }\n+            let Ok(text) = std::str::from_utf8(&bytes) else {\n+                continue;\n+            };\n+\n+            if let Ok(manifest) = parse_aof_manifest(text) {\n+                let formatted = format_aof_manifest(&manifest);\n+                assert_eq!(\n+                    parse_aof_manifest(&formatted).map_err(|err| format!(\n+                        \"reparse formatted seed {}: {err:?}\",\n+                        path.display()\n+                    ))?,\n+                    manifest,\n+                    \"formatted manifest did not round-trip for {}\",\n+                    path.display()\n+                );\n+            }\n+        }\n+        Ok(())\n+    }\n+\n     // \u2500\u2500 RDB tests \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n \n     use super::{"
    },
