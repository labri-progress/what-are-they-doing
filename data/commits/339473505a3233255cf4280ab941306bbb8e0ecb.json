-        <h3 className=\"text-sm font-medium text-foreground\">Suggested Actions</h3>\n-        {stats.critical > 0 && (\n-          <span className=\"px-2 py-0.5 rounded-full bg-red-500/20 text-red-400 text-xs\">\n-            {stats.critical} critical\n-          </span>\n-        )}\n-        {stats.high > 0 && stats.critical === 0 && (\n-          <span className=\"px-2 py-0.5 rounded-full bg-orange-500/20 text-orange-400 text-xs\">\n-            {stats.high} high priority\n-          </span>\n-        )}\n-      </div>\n+    <div data-tour=\"mission-suggestions\" className=\"mb-4\">\n+      <div className=\"flex items-center gap-2 flex-wrap\">\n+        <div className=\"flex items-center gap-1.5 text-muted-foreground mr-1\">\n+          <Lightbulb className=\"w-4 h-4 text-purple-400\" />\n+          <span className=\"text-xs font-medium\">Actions:</span>\n+        </div>\n \n-      <div className=\"flex flex-wrap gap-3\">\n-        {suggestions.slice(0, 4).map((suggestion) => {\n+        {/* Inline suggestion chips */}\n+        {suggestions.slice(0, 6).map((suggestion) => {\n           const Icon = MISSION_ICONS[suggestion.type]\n           const style = PRIORITY_STYLES[suggestion.priority]\n           const isExpanded = expandedId === suggestion.id\n           const isProcessing = processingId === suggestion.id\n           const snoozeRemaining = getSnoozeRemaining(suggestion.id)\n \n           return (\n-            <div\n-              key={suggestion.id}\n-              className={`rounded-lg border ${style.border} ${style.bg} transition-all ${\n-                isExpanded ? 'w-full md:w-96' : 'w-auto'\n-              }`}\n-            >\n-              {/* Collapsed/Header view */}\n-              <div\n-                className={`p-3 cursor-pointer ${isExpanded ? '' : 'hover:scale-105'} transition-transform`}\n+            <div key={suggestion.id} className=\"relative\">\n+              {/* Compact chip */}\n+              <button\n                 onClick={() => setExpandedId(isExpanded ? null : suggestion.id)}\n+                className={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-xs font-medium transition-all hover:scale-105 ${style.border} ${style.bg} ${style.text}`}\n               >\n-                <div className=\"flex items-center gap-2 mb-1\">\n-                  <Icon className={`w-4 h-4 ${style.text}`} />\n-                  <span className=\"font-medium text-sm text-foreground\">{suggestion.title}</span>\n-                  <span className={`text-xs px-1.5 py-0.5 rounded ${style.badge} ${style.text}`}>\n-                    {suggestion.priority}\n-                  </span>\n-                  {isProcessing && (\n-                    <div className=\"ml-auto spinner w-4 h-4\" />\n-                  )}\n-                </div>\n-                <p className=\"text-xs text-muted-foreground\">{suggestion.description}</p>\n-                {!isExpanded && (\n-                  <div className=\"mt-2 flex items-center gap-1 text-xs text-muted-foreground\">\n-                    <ChevronRight className=\"w-3 h-3\" />\n-                    <span>Click to expand</span>\n-                  </div>\n+                <Icon className=\"w-3 h-3\" />\n+                <span className=\"max-w-[150px] truncate\">{suggestion.title}</span>\n+                {suggestion.priority === 'critical' && (\n+                  <span className=\"w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse\" />\n                 )}\n-                {snoozeRemaining && snoozeRemaining > 0 && (\n-                  <div className=\"mt-1 text-xs text-purple-400\">\n-                    Snoozed for {formatTimeRemaining(snoozeRemaining)}\n-                  </div>\n-                )}\n-              </div>\n+                {isProcessing && <div className=\"spinner w-3 h-3\" />}\n+                <ChevronDown className={`w-3 h-3 transition-transform ${isExpanded ? 'rotate-180' : ''}`} />\n+              </button>\n \n-              {/* Expanded view with details and actions */}\n+              {/* Expanded dropdown */}\n               {isExpanded && (\n-                <div className=\"px-3 pb-3 border-t border-current/20 mt-2 pt-3\">\n-                  {/* Context details */}\n-                  {suggestion.context.details && suggestion.context.details.length > 0 && (\n-                    <div className=\"text-xs text-muted-foreground mb-3\">\n-                      <strong className=\"text-foreground\">Details:</strong>\n-                      <ul className=\"mt-1 ml-4 list-disc space-y-1\">\n-                        {suggestion.context.details.slice(0, 3).map((detail, idx) => (\n-                          <li key={idx}>{detail}</li>\n-                        ))}\n-                        {suggestion.context.details.length > 3 && (\n-                          <li className=\"text-muted-foreground/70\">\n-                            ...and {suggestion.context.details.length - 3} more\n-                          </li>\n-                        )}\n-                      </ul>\n+                <div className={`absolute top-full left-0 mt-1 z-50 w-72 rounded-lg border ${style.border} ${style.bg} backdrop-blur-sm shadow-xl`}>\n+                  <div className=\"p-3\">\n+                    {/* Description */}\n+                    <p className=\"text-xs text-muted-foreground mb-2\">{suggestion.description}</p>\n+\n+                    {/* Context details */}\n+                    {suggestion.context.details && suggestion.context.details.length > 0 && (\n+                      <div className=\"text-xs text-muted-foreground mb-3 max-h-20 overflow-y-auto\">\n+                        <ul className=\"ml-3 list-disc space-y-0.5\">\n+                          {suggestion.context.details.slice(0, 3).map((detail, idx) => (\n+                            <li key={idx} className=\"truncate\">{detail}</li>\n+                          ))}\n+                          {suggestion.context.details.length > 3 && (\n+                            <li className=\"text-muted-foreground/70\">\n+                              +{suggestion.context.details.length - 3} more\n+                            </li>\n+                          )}\n+                        </ul>\n+                      </div>\n+                    )}\n+\n+                    {snoozeRemaining && snoozeRemaining > 0 && (\n+                      <div className=\"text-xs text-purple-400 mb-2\">\n+                        Snoozed for {formatTimeRemaining(snoozeRemaining)}\n+                      </div>\n+                    )}\n+\n+                    {/* Action buttons */}\n+                    <div className=\"flex flex-wrap gap-1.5\">\n+                      <button\n+                        onClick={() => handleAction(suggestion)}\n+                        disabled={isProcessing}\n+                        className={`flex-1 px-2 py-1.5 rounded text-xs font-medium transition-colors ${\n+                          suggestion.priority === 'critical'\n+                            ? 'bg-red-500 hover:bg-red-600 text-white'\n+                            : suggestion.priority === 'high'\n+                            ? 'bg-orange-500 hover:bg-orange-600 text-white'\n+                            : 'bg-purple-500 hover:bg-purple-600 text-white'\n+                        } disabled:opacity-50`}\n+                      >\n+                        {suggestion.action.label}\n+                      </button>\n+                      <button\n+                        onClick={() => handleRepair(suggestion)}\n+                        disabled={isProcessing}\n+                        className=\"px-2 py-1.5 rounded text-xs font-medium bg-green-500/20 hover:bg-green-500/30 text-green-400 transition-colors flex items-center gap-1\"\n+                        title=\"Klaude Repair - automatically fix this issue\"\n+                      >\n+                        <Wrench className=\"w-3 h-3\" />\n+                        Repair\n+                      </button>\n+                      <button\n+                        onClick={(e) => handleSnooze(e, suggestion)}\n+                        className=\"px-2 py-1.5 rounded text-xs font-medium bg-secondary/50 hover:bg-secondary transition-colors\"\n+                        title=\"Snooze for 24 hours\"\n+                      >\n+                        <Clock className=\"w-3 h-3\" />\n+                      </button>\n+                      <button\n+                        onClick={(e) => handleDismiss(e, suggestion)}\n+                        className=\"px-2 py-1.5 rounded text-xs font-medium bg-secondary/50 hover:bg-secondary transition-colors\"\n+                        title=\"Dismiss\"\n+                      >\n+                        <X className=\"w-3 h-3\" />\n+                      </button>\n                     </div>\n-                  )}\n-\n-                  {/* Action buttons */}\n-                  <div className=\"flex gap-2\">\n-                    <button\n-                      onClick={() => handleAction(suggestion)}\n-                      disabled={isProcessing}\n-                      className={`flex-1 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${\n-                        suggestion.priority === 'critical'\n-                          ? 'bg-red-500 hover:bg-red-600 text-white'\n-                          : suggestion.priority === 'high'\n-                          ? 'bg-orange-500 hover:bg-orange-600 text-white'\n-                          : 'bg-purple-500 hover:bg-purple-600 text-white'\n-                      } disabled:opacity-50 disabled:cursor-not-allowed`}\n-                    >\n-                      {isProcessing ? (\n-                        <span className=\"flex items-center justify-center gap-2\">\n-                          <div className=\"spinner w-4 h-4\" /> Processing...\n-                        </span>\n-                      ) : (\n-                        suggestion.action.label\n-                      )}\n-                    </button>\n-                    <button\n-                      onClick={() => handleSnooze(suggestion)}\n-                      className=\"px-3 py-2 rounded-lg text-sm font-medium bg-purple-500/20 hover:bg-purple-500/30 text-purple-400 transition-colors flex items-center gap-1\"\n-                      title=\"Snooze for 24 hours\"\n-                    >\n-                      <Clock className=\"w-4 h-4\" />\n-                      Snooze\n-                    </button>\n-                    <button\n-                      onClick={() => handleDismiss(suggestion)}\n-                      className=\"px-3 py-2 rounded-lg text-sm font-medium bg-secondary/50 hover:bg-secondary transition-colors\"\n-                      title=\"Dismiss this suggestion\"\n-                    >\n-                      <X className=\"w-4 h-4\" />\n-                    </button>\n                   </div>\n                 </div>\n               )}\n             </div>\n           )\n         })}\n-      </div>\n \n-      {suggestions.length > 4 && (\n-        <div className=\"mt-2 text-xs text-muted-foreground\">\n-          +{suggestions.length - 4} more suggestions\n-        </div>\n-      )}\n+        {/* Stats badges */}\n+        {stats.critical > 0 && (\n+          <span className=\"px-1.5 py-0.5 rounded-full bg-red-500/20 text-red-400 text-[10px]\">\n+            {stats.critical} critical\n+          </span>\n+        )}\n+        {stats.high > 0 && stats.critical === 0 && (\n+          <span className=\"px-1.5 py-0.5 rounded-full bg-orange-500/20 text-orange-400 text-[10px]\">\n+            {stats.high} high\n+          </span>\n+        )}\n+\n+        {suggestions.length > 6 && (\n+          <span className=\"text-[10px] text-muted-foreground\">\n+            +{suggestions.length - 6} more\n+          </span>\n+        )}\n+      </div>\n     </div>\n   )\n }"
