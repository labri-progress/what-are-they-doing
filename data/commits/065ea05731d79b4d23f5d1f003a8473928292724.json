      "patch": "@@ -175,7 +175,7 @@ function MarketplaceCard({ item, onInstall, onRemove, isInstalled }: {\n       {/* Thumbnail */}\n       <div className=\"relative\">\n         {item.screenshot ? (\n-          <div className=\"h-36 bg-muted overflow-hidden\">\n+          <div className=\"h-20 bg-muted overflow-hidden\">\n             <img\n               src={item.screenshot}\n               alt={item.name}"
