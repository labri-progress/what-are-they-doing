      "patch": "@@ -474,6 +474,54 @@\n       \"now_ms\": 45003,\n       \"argv\": [\"OBJECT\", \"FREQ\", \"obj_hll\"],\n       \"expect\": { \"kind\": \"integer\", \"value\": 0 }\n+    },\n+    {\n+      \"name\": \"object_encoding_stream_setup\",\n+      \"now_ms\": 50000,\n+      \"argv\": [\"XADD\", \"obj_stream\", \"50000-0\", \"field\", \"value\"],\n+      \"expect\": { \"kind\": \"bulk\", \"value\": \"50000-0\" }\n+    },\n+    {\n+      \"name\": \"object_encoding_stream_radix_tree\",\n+      \"now_ms\": 50001,\n+      \"argv\": [\"OBJECT\", \"ENCODING\", \"obj_stream\"],\n+      \"expect\": { \"kind\": \"bulk\", \"value\": \"stream\" }\n+    },\n+    {\n+      \"name\": \"object_idletime_stream\",\n+      \"now_ms\": 55001,\n+      \"argv\": [\"OBJECT\", \"IDLETIME\", \"obj_stream\"],\n+      \"expect\": { \"kind\": \"integer\", \"value\": 5 }\n+    },\n+    {\n+      \"name\": \"object_refcount_stream\",\n+      \"now_ms\": 55002,\n+      \"argv\": [\"OBJECT\", \"REFCOUNT\", \"obj_stream\"],\n+      \"expect\": { \"kind\": \"integer\", \"value\": 1 }\n+    },\n+    {\n+      \"name\": \"object_encoding_geo_setup\",\n+      \"now_ms\": 60000,\n+      \"argv\": [\"GEOADD\", \"obj_geo\", \"-122.4194\", \"37.7749\", \"san_francisco\"],\n+      \"expect\": { \"kind\": \"integer\", \"value\": 1 }\n+    },\n+    {\n+      \"name\": \"object_encoding_geo_skiplist\",\n+      \"now_ms\": 60001,\n+      \"argv\": [\"OBJECT\", \"ENCODING\", \"obj_geo\"],\n+      \"expect\": { \"kind\": \"bulk\", \"value\": \"skiplist\" }\n+    },\n+    {\n+      \"name\": \"object_idletime_geo\",\n+      \"now_ms\": 65001,\n+      \"argv\": [\"OBJECT\", \"IDLETIME\", \"obj_geo\"],\n+      \"expect\": { \"kind\": \"integer\", \"value\": 5 }\n+    },\n+    {\n+      \"name\": \"object_refcount_geo\",\n+      \"now_ms\": 65002,\n+      \"argv\": [\"OBJECT\", \"REFCOUNT\", \"obj_geo\"],\n+      \"expect\": { \"kind\": \"integer\", \"value\": 1 }\n     }\n   ]\n }"
