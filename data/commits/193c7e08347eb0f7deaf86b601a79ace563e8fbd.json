      "patch": "@@ -5,7 +5,7 @@ import App from './App';\n \n ReactDOM.createRoot(document.getElementById('root')!).render(\n   <React.StrictMode>\n-    <ThemeProvider colorMode=\"night\">\n+    <ThemeProvider colorMode=\"night\" nightScheme=\"dark_dimmed\">\n       <BaseStyles>\n         <App />\n       </BaseStyles>"
