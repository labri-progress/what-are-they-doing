{
  "message": "\ud83d\udc1b Fix dark mode text colors across entire app (#11)\n\nAdd data-color-mode='dark' and data-dark-theme='dark_dimmed' attributes\nto <html> element so Primer CSS variables resolve to dark theme values.\nSet nightScheme='dark_dimmed' on ThemeProvider. This fixes all text being\ninvisible (dark on dark) throughout the app.\n\nSigned-off-by: Andrew Anderson <andy@clubanderson.com>",
  "files": [
    {
      "sha": "b639f61ee981bcb4ca0a04023713457ccf8eaf7f",
      "filename": "web/index.html",
      "status": "modified",
      "additions": 4,
      "deletions": 1,
      "changes": 5,
      "blob_url": "https://github.com/kubestellar/copilot-remote/blob/193c7e08347eb0f7deaf86b601a79ace563e8fbd/web%2Findex.html",
      "raw_url": "https://github.com/kubestellar/copilot-remote/raw/193c7e08347eb0f7deaf86b601a79ace563e8fbd/web%2Findex.html",
      "contents_url": "https://api.github.com/repos/kubestellar/copilot-remote/contents/web%2Findex.html?ref=193c7e08347eb0f7deaf86b601a79ace563e8fbd",
      "patch": "@@ -1,10 +1,13 @@\n <!DOCTYPE html>\n-<html lang=\"en\">\n+<html lang=\"en\" data-color-mode=\"dark\" data-dark-theme=\"dark_dimmed\">\n   <head>\n     <meta charset=\"UTF-8\" />\n     <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\" />\n     <meta name=\"theme-color\" content=\"#0d1117\" />\n     <title>Copilot Remote</title>\n+    <style>\n+      html, body { margin: 0; padding: 0; background: #1c2128; color: #adbac7; }\n+    </style>\n   </head>\n   <body>\n     <div id=\"root\"></div>"
    },
