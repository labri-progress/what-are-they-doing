      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankenterm/contents/fuzz%2Fcorpus%2Fpattern_pack_parser%2Fseed_regex_edge.toml?ref=ad28aa9994958ea7f38c58abcafd2f00ac18f624",
      "patch": "@@ -0,0 +1,20 @@\n+name = \"edge:cases\"\n+version = \"0.0.1\"\n+\n+[[rules]]\n+id = \"edge.unicode\"\n+agent_type = \"any\"\n+event_type = \"info\"\n+severity = \"info\"\n+anchors = [\"\\u00e9\", \"\\u4e2d\"]\n+regex = \"[\\\\u00C0-\\\\u024F]+\"\n+description = \"Unicode identifier detection\"\n+\n+[[rules]]\n+id = \"edge.long\"\n+agent_type = \"any\"\n+event_type = \"error\"\n+severity = \"error\"\n+anchors = [\"AAAA\"]\n+regex = \"A{4,100}\"\n+description = \"Repetition range\""
    },
