      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankenterm/contents/fuzz%2Fcorpus%2Fconfig_toml_parser%2Fseed_tuning_edge.toml?ref=ad28aa9994958ea7f38c58abcafd2f00ac18f624",
      "patch": "@@ -0,0 +1,15 @@\n+[wa.tuning.runtime]\n+tick_interval_ms = 1\n+max_concurrent_panes = 1\n+task_queue_depth = 0\n+\n+[wa.tuning.compression]\n+level = 22\n+threshold_bytes = 0\n+dictionary_size = 0\n+\n+[wa.tuning.backpressure]\n+green_threshold = 0\n+yellow_threshold = 0\n+red_threshold = 0\n+hysteresis_ms = 0"
    },
    {
      "sha": "fa3a6fbbb4a0bfa58e99dadbe0cd4467056d3553",
      "filename": "fuzz/corpus/pattern_pack_parser/seed_multi_rules.toml",
      "status": "added",
      "additions": 29,
      "deletions": 0,
      "changes": 29,
      "blob_url": "https://github.com/Dicklesworthstone/frankenterm/blob/ad28aa9994958ea7f38c58abcafd2f00ac18f624/fuzz%2Fcorpus%2Fpattern_pack_parser%2Fseed_multi_rules.toml",
      "raw_url": "https://github.com/Dicklesworthstone/frankenterm/raw/ad28aa9994958ea7f38c58abcafd2f00ac18f624/fuzz%2Fcorpus%2Fpattern_pack_parser%2Fseed_multi_rules.toml",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankenterm/contents/fuzz%2Fcorpus%2Fpattern_pack_parser%2Fseed_multi_rules.toml?ref=ad28aa9994958ea7f38c58abcafd2f00ac18f624",
      "patch": "@@ -0,0 +1,29 @@\n+name = \"test:multi\"\n+version = \"1.0.0\"\n+\n+[[rules]]\n+id = \"err.panic\"\n+agent_type = \"any\"\n+event_type = \"error\"\n+severity = \"critical\"\n+anchors = [\"panic\", \"PANIC\", \"thread.*panicked\"]\n+regex = \"(?i)panic|thread '.*' panicked\"\n+description = \"Rust panic detection\"\n+\n+[[rules]]\n+id = \"warn.deprecation\"\n+agent_type = \"npm\"\n+event_type = \"warning\"\n+severity = \"warning\"\n+anchors = [\"deprecated\", \"DEPRECATED\"]\n+regex = \"(?:npm WARN|WARN) deprecated\"\n+description = \"NPM deprecation warnings\"\n+\n+[[rules]]\n+id = \"prog.download\"\n+agent_type = \"any\"\n+event_type = \"progress\"\n+severity = \"info\"\n+anchors = [\"Downloading\", \"downloading\"]\n+regex = \"[Dd]ownloading .+ \\\\(\\\\d+(\\\\.\\\\d+)? [KMG]i?B\\\\)\"\n+description = \"Download progress\""
    },
    {
      "sha": "c47529dd786d9dcfd51e4a1e48ed9d9b9ca7c73f",
      "filename": "fuzz/corpus/pattern_pack_parser/seed_regex_edge.toml",
      "status": "added",
      "additions": 20,
      "deletions": 0,
      "changes": 20,
      "blob_url": "https://github.com/Dicklesworthstone/frankenterm/blob/ad28aa9994958ea7f38c58abcafd2f00ac18f624/fuzz%2Fcorpus%2Fpattern_pack_parser%2Fseed_regex_edge.toml",
