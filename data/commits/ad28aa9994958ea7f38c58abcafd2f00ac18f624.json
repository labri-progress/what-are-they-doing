{
  "message": "test: expand fuzz corpus seeds + validation regression test\n\n- scan_pipeline_quick: 8 new seeds (truecolor, UTF-8 multibyte, trigger\n  keywords, newline/escape interleave, long SGR params, OSC hyperlinks,\n  DCS/APC/SOS/PM, binary noise with valid escapes)\n- config_toml_parser: 2 new seeds (resize+workflows+ssh_domains, tuning edge values)\n- pattern_pack_parser: 2 new seeds (multi-rule pack, Unicode/regex edge cases)\n- scan_pipeline.rs: fuzz_corpus_seeds_no_panic regression test validates\n  all 8 scan seeds produce correct input_bytes without panic\n\nCo-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>",
  "files": [
    {
      "sha": "015275d8507b07d6e6757f00ad98818161b4d99a",
      "filename": "crates/frankenterm-core/src/scan_pipeline.rs",
      "status": "modified",
      "additions": 32,
      "deletions": 0,
      "changes": 32,
      "blob_url": "https://github.com/Dicklesworthstone/frankenterm/blob/ad28aa9994958ea7f38c58abcafd2f00ac18f624/crates%2Ffrankenterm-core%2Fsrc%2Fscan_pipeline.rs",
      "raw_url": "https://github.com/Dicklesworthstone/frankenterm/raw/ad28aa9994958ea7f38c58abcafd2f00ac18f624/crates%2Ffrankenterm-core%2Fsrc%2Fscan_pipeline.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankenterm/contents/crates%2Ffrankenterm-core%2Fsrc%2Fscan_pipeline.rs?ref=ad28aa9994958ea7f38c58abcafd2f00ac18f624",
      "patch": "@@ -968,4 +968,36 @@ mod tests {\n             batch_output.metrics.logical_lines\n         );\n     }\n+\n+    /// Validate all fuzz corpus seeds don't panic and produce sane output.\n+    #[test]\n+    fn fuzz_corpus_seeds_no_panic() {\n+        let seeds: &[&[u8]] = &[\n+            // Truecolor with dangling ESC at end\n+            b\"\\x1b[38;2;255;0;128mTruecolor\\x1b[0m \\x1b[48;5;196m256col\\x1b[0m\\x1b\",\n+            // Multi-byte UTF-8 mixed with ANSI\n+            b\"\\x1b[1m\\xe4\\xb8\\xad\\xe6\\x96\\x87\\x1b[0m \\xf0\\x9f\\x9a\\x80 A\\xcc\\x81\\n\",\n+            // Trigger keywords\n+            b\"ERROR: disk full\\n\\x1b[33mwarning\\x1b[0m: unused var\\n   Compiling foo v0.1\\ntest result: FAILED. 3 passed; 1 failed\\n\",\n+            // Newline/escape interleave\n+            b\"\\n\\n\\n\\x1b[\\n\\x1b[31m\\n\\x1b[0m\\n\\n\\x1b[1;2;3;4;5;6;7;8;9m\\n\\x1b\",\n+            // Long SGR param sequence\n+            b\"\\x1b[0;1;2;3;4;5;7;8;9;21;53;38;2;100;200;50;48;2;10;20;30mSTYLED\\x1b[0m\",\n+            // OSC with BEL and ST terminators\n+            b\"\\x1b]0;Window Title\\x07\\x1b]8;;https://example.com\\x1b\\\\Link\\x1b]8;;\\x1b\\\\\\n\",\n+            // DCS/APC/SOS/PM sequences\n+            b\"\\x1bP+q544d\\x1b\\\\\\x1b_APC content\\x1b\\\\\\x1bX SOS \\x1b\\\\\\x1b^ PM \\x1b\\\\\\n\",\n+            // Binary noise mixed with valid escapes\n+            b\"\\xff\\xfe\\x80\\x1b[32m\\x00\\x01\\x02OK\\x1b[0m\\xff\\xc0\\n\",\n+        ];\n+\n+        for (i, seed) in seeds.iter().enumerate() {\n+            let output = quick_scan(seed);\n+            assert_eq!(\n+                output.input_bytes,\n+                seed.len() as u64,\n+                \"seed {i}: input_bytes mismatch\"\n+            );\n+        }\n+    }\n }"
    },
    {
      "sha": "359746decf1198fbad54a44e90b37fec4867c80f",
      "filename": "fuzz/corpus/config_toml_parser/seed_resize_workflows.toml",
      "status": "added",
      "additions": 28,
      "deletions": 0,
      "changes": 28,
      "blob_url": "https://github.com/Dicklesworthstone/frankenterm/blob/ad28aa9994958ea7f38c58abcafd2f00ac18f624/fuzz%2Fcorpus%2Fconfig_toml_parser%2Fseed_resize_workflows.toml",
      "raw_url": "https://github.com/Dicklesworthstone/frankenterm/raw/ad28aa9994958ea7f38c58abcafd2f00ac18f624/fuzz%2Fcorpus%2Fconfig_toml_parser%2Fseed_resize_workflows.toml",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankenterm/contents/fuzz%2Fcorpus%2Fconfig_toml_parser%2Fseed_resize_workflows.toml?ref=ad28aa9994958ea7f38c58abcafd2f00ac18f624",
      "patch": "@@ -0,0 +1,28 @@\n+[wa]\n+watcher_poll_ms = 250\n+capture_max_bytes = 131072\n+\n+[wa.resize]\n+scorecard_enabled = true\n+gate_enabled = true\n+fast_threshold_ms = 500\n+slow_threshold_ms = 2000\n+max_pending = 20\n+\n+[wa.patterns]\n+enable_builtin = true\n+extra_pack_dirs = [\"/home/user/.config/frankenterm/packs\"]\n+\n+[[wa.workflows]]\n+name = \"deploy\"\n+trigger = \"deploy_complete\"\n+steps = [\"notify\", \"log\"]\n+\n+[[ssh_domains]]\n+name = \"prod\"\n+remote_address = \"prod.example.com\"\n+username = \"deploy\"\n+\n+[[ssh_domains]]\n+name = \"staging\"\n+remote_address = \"staging.example.com\""
    },
    {
      "sha": "e1afd54c1d4e9808c85f9870131fd3a578f02fbc",
      "filename": "fuzz/corpus/config_toml_parser/seed_tuning_edge.toml",
      "status": "added",
