      "patch": "@@ -0,0 +1,11 @@\n+<!DOCTYPE html>\n+<html lang=\"en\">\n+  <head>\n+    <meta charset=\"UTF-8\">\n+    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n+    <title>Clippings</title>\n+  </head>\n+  <body>\n+    <a href=\"javascript:(function()%7Bfunction%20runClippingsBookmarklet()%20%7B%0A%20%20window.alert(%22Clippings%20bookmarklet%20placeholder%22)%3B%0A%7D%3BrunClippingsBookmarklet()%3B%7D)()\">Export Kindle Highlights</a>\n+  </body>\n+</html>"
