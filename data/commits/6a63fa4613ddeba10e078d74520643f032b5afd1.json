      "raw_url": "https://github.com/Dicklesworthstone/frankenredis/raw/6a63fa4613ddeba10e078d74520643f032b5afd1/crates%2Ffr-conformance%2Ffixtures%2Fcore_hyperloglog.json",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankenredis/contents/crates%2Ffr-conformance%2Ffixtures%2Fcore_hyperloglog.json?ref=6a63fa4613ddeba10e078d74520643f032b5afd1",
      "patch": "@@ -1206,6 +1206,120 @@\n         \"kind\": \"simple\",\n         \"value\": \"string\"\n       }\n+    },\n+    {\n+      \"name\": \"pfmerge_ttl_setup_dest\",\n+      \"now_ms\": 300,\n+      \"argv\": [\n+        \"PFADD\",\n+        \"hll_ttl_dest\",\n+        \"x\",\n+        \"y\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"integer\",\n+        \"value\": 1\n+      }\n+    },\n+    {\n+      \"name\": \"pfmerge_ttl_set_expire\",\n+      \"now_ms\": 300,\n+      \"argv\": [\n+        \"PEXPIRE\",\n+        \"hll_ttl_dest\",\n+        \"60000\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"integer\",\n+        \"value\": 1\n+      }\n+    },\n+    {\n+      \"name\": \"pfmerge_ttl_verify_ttl_before\",\n+      \"now_ms\": 300,\n+      \"argv\": [\n+        \"PTTL\",\n+        \"hll_ttl_dest\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"integer\",\n+        \"value\": 60000\n+      }\n+    },\n+    {\n+      \"name\": \"pfmerge_ttl_setup_src\",\n+      \"now_ms\": 300,\n+      \"argv\": [\n+        \"PFADD\",\n+        \"hll_ttl_src\",\n+        \"z\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"integer\",\n+        \"value\": 1\n+      }\n+    },\n+    {\n+      \"name\": \"pfmerge_ttl_merge_preserves_ttl\",\n+      \"now_ms\": 300,\n+      \"argv\": [\n+        \"PFMERGE\",\n+        \"hll_ttl_dest\",\n+        \"hll_ttl_src\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"simple\",\n+        \"value\": \"OK\"\n+      }\n+    },\n+    {\n+      \"name\": \"pfmerge_ttl_verify_ttl_after\",\n+      \"now_ms\": 300,\n+      \"argv\": [\n+        \"PTTL\",\n+        \"hll_ttl_dest\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"integer\",\n+        \"value\": 60000\n+      }\n+    },\n+    {\n+      \"name\": \"pfmerge_ttl_count_after_merge\",\n+      \"now_ms\": 300,\n+      \"argv\": [\n+        \"PFCOUNT\",\n+        \"hll_ttl_dest\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"integer\",\n+        \"value\": 3\n+      }\n+    },\n+    {\n+      \"name\": \"pfmerge_no_ttl_on_new_dest\",\n+      \"now_ms\": 300,\n+      \"argv\": [\n+        \"PFMERGE\",\n+        \"hll_ttl_new_dest\",\n+        \"hll_ttl_src\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"simple\",\n+        \"value\": \"OK\"\n+      }\n+    },\n+    {\n+      \"name\": \"pfmerge_no_ttl_on_new_dest_verify\",\n+      \"now_ms\": 300,\n+      \"argv\": [\n+        \"TTL\",\n+        \"hll_ttl_new_dest\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"integer\",\n+        \"value\": -1\n+      }\n     }\n   ]\n }"
