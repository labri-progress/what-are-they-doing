  "message": "native: swiglu_clamp + rope_apply byte-equal vs browser (7/15)",
  "files": [
    {
      "sha": "1b9c0693e09c67161114db65565edbacfe26cd5a",
      "filename": "tests/conformance/shaders.html",
      "status": "modified",
      "additions": 38,
      "deletions": 0,
      "changes": 38,
      "blob_url": "https://github.com/teamchong/textsift/blob/e73042ad10e753854e3b7cf9a40b9f745961642c/tests%2Fconformance%2Fshaders.html",
      "raw_url": "https://github.com/teamchong/textsift/raw/e73042ad10e753854e3b7cf9a40b9f745961642c/tests%2Fconformance%2Fshaders.html",
      "contents_url": "https://api.github.com/repos/teamchong/textsift/contents/tests%2Fconformance%2Fshaders.html?ref=e73042ad10e753854e3b7cf9a40b9f745961642c",
      "patch": "@@ -140,6 +140,44 @@\n             };\n           },\n         },\n+        {\n+          name: \"swiglu_clamp\",\n+          build() {\n+            const rows = 4, dff = 128;\n+            return {\n+              uniform: { binding: 0, bytes: dimsBuf([{tag:\"u32\",value:rows},{tag:\"u32\",value:dff},{tag:\"u32\",value:0},{tag:\"u32\",value:0}]) },\n+              inputs: [\n+                // gate_up has 2*dff entries per row (gate, up interleaved).\n+                { binding: 1, name: \"gate_up\", bytes: new Uint8Array(rngF32(7, rows * 2 * dff, 3.0).buffer) },\n+              ],\n+              output: { binding: 2, elements: rows * dff, dtype: \"f32\" },\n+              dispatch: [Math.ceil(rows * dff / 64), 1, 1],\n+            };\n+          },\n+        },\n+        {\n+          name: \"rope_apply\",\n+          build() {\n+            const T = 4, H = 4, head_dim = 32;\n+            const qkBytes = T * H * head_dim * 2; // f16\n+            return {\n+              uniform: { binding: 0, bytes: dimsBuf([{tag:\"u32\",value:T},{tag:\"u32\",value:H},{tag:\"u32\",value:head_dim},{tag:\"u32\",value:0}]) },\n+              inputs: [\n+                { binding: 2, name: \"cos_tab\", bytes: rngF16(8, T * head_dim / 2, 1.0) },\n+                { binding: 3, name: \"sin_tab\", bytes: rngF16(9, T * head_dim / 2, 1.0) },\n+              ],\n+              // qk is read+write, so it lives at the output binding with\n+              // an initial value uploaded before dispatch.\n+              output: {\n+                binding: 1,\n+                elements: T * H * head_dim,\n+                dtype: \"f16\",\n+              },\n+              outputInitial: rngF16(10, T * H * head_dim, 1.0),\n+              dispatch: [Math.ceil(T * H * (head_dim / 2) / 64), 1, 1],\n+            };\n+          },\n+        },\n       ];\n \n       try {"
    },
