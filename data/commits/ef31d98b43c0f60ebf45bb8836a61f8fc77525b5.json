      "contents_url": "https://api.github.com/repos/gastownhall/beads/contents/analyze_duplicates.sh?ref=ef31d98b43c0f60ebf45bb8836a61f8fc77525b5",
      "patch": "@@ -0,0 +1,13 @@\n+#!/bin/bash\n+# Analyze duplicate issues\n+\n+echo \"# Duplicate Issues Report\"\n+echo \"\"\n+echo \"Generated: $(date)\"\n+echo \"\"\n+\n+./bd list --json | jq -r 'group_by(.title) | .[] | select(length > 1) | {\n+  title: .[0].title,\n+  count: length,\n+  issues: [.[] | {id, status, created_at}]\n+} | \"## \\(.title)\\nCount: \\(.count)\\n\" + (.issues | map(\"- \\(.id) (\\(.status)) created \\(.created_at)\") | join(\"\\n\")) + \"\\n\"'"
    },
