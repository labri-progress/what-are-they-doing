      "patch": "@@ -0,0 +1,46 @@\n+[\n+  {\n+    \"name\": \"root\",\n+    \"reaches\": [\n+      \"e_memory\", \"e_alloc\", \"e_resetHeap\", \"e_getHeapUsed\",\n+      \"e_sha1_hash\", \"e_sha1_hash_object\",\n+      \"e_zlib_inflate\", \"e_zlib_inflate_tracked\", \"e_zlib_deflate\",\n+      \"e_parse_object_header\", \"e_serialize_object\", \"e_parse_tree\",\n+      \"e_pack_parse_header\", \"e_pack_parse_entry_header\", \"e_pack_build\",\n+      \"e_delta_apply\", \"e_delta_create\",\n+      \"e_pktline_encode\", \"e_pktline_decode\",\n+      \"e_simd_memeql\", \"e_simd_memchr\",\n+      \"e_libgit2_init\", \"e_libgit2_shutdown\",\n+      \"e_libgit2_diff\", \"e_libgit2_revwalk\", \"e_libgit2_blame\",\n+      \"e__start\"\n+    ],\n+    \"root\": true\n+  },\n+  { \"name\": \"e_memory\", \"export\": \"memory\" },\n+  { \"name\": \"e_alloc\", \"export\": \"alloc\" },\n+  { \"name\": \"e_resetHeap\", \"export\": \"resetHeap\" },\n+  { \"name\": \"e_getHeapUsed\", \"export\": \"getHeapUsed\" },\n+  { \"name\": \"e_sha1_hash\", \"export\": \"sha1_hash\" },\n+  { \"name\": \"e_sha1_hash_object\", \"export\": \"sha1_hash_object\" },\n+  { \"name\": \"e_zlib_inflate\", \"export\": \"zlib_inflate\" },\n+  { \"name\": \"e_zlib_inflate_tracked\", \"export\": \"zlib_inflate_tracked\" },\n+  { \"name\": \"e_zlib_deflate\", \"export\": \"zlib_deflate\" },\n+  { \"name\": \"e_parse_object_header\", \"export\": \"parse_object_header\" },\n+  { \"name\": \"e_serialize_object\", \"export\": \"serialize_object\" },\n+  { \"name\": \"e_parse_tree\", \"export\": \"parse_tree\" },\n+  { \"name\": \"e_pack_parse_header\", \"export\": \"pack_parse_header\" },\n+  { \"name\": \"e_pack_parse_entry_header\", \"export\": \"pack_parse_entry_header\" },\n+  { \"name\": \"e_pack_build\", \"export\": \"pack_build\" },\n+  { \"name\": \"e_delta_apply\", \"export\": \"delta_apply\" },\n+  { \"name\": \"e_delta_create\", \"export\": \"delta_create\" },\n+  { \"name\": \"e_pktline_encode\", \"expo