{
  "message": "Optimize WASM binary from 1.2MB to 791KB\n\nAdd wasm-metadce + wasm-opt -Oz post-processing to the build pipeline.\nRemoves 840 unused libgit2/libc exports, enabling dead code elimination\nof unreachable functions. Only 27 exports (our 22 Zig functions + 5\nlibgit2 wrappers) are retained.\n\nBuild: Zig ReleaseSmall -> wasm-metadce -> wasm-opt -Oz",
  "files": [
    {
      "sha": "8418e9961c0710c6a8c455710e64d4fc87ec2d48",
      "filename": "package.json",
      "status": "modified",
      "additions": 1,
      "deletions": 1,
      "changes": 2,
      "blob_url": "https://github.com/teamchong/gitmode/blob/d8987c77fc4e6e26a2aa5283aafb98b23b86bb6e/package.json",
      "raw_url": "https://github.com/teamchong/gitmode/raw/d8987c77fc4e6e26a2aa5283aafb98b23b86bb6e/package.json",
      "contents_url": "https://api.github.com/repos/teamchong/gitmode/contents/package.json?ref=d8987c77fc4e6e26a2aa5283aafb98b23b86bb6e",
      "patch": "@@ -5,7 +5,7 @@\n   \"description\": \"Git server on Cloudflare Workers \u2014 Zig WASM engine with SIMD\",\n   \"type\": \"module\",\n   \"scripts\": {\n-    \"build:wasm\": \"cd wasm && zig build wasm && mkdir -p ../src/wasm && cp zig-out/bin/gitmode.wasm ../src/wasm/\",\n+    \"build:wasm\": \"cd wasm && zig build wasm -Doptimize=ReleaseSmall && mkdir -p ../src/wasm && wasm-metadce --enable-simd --enable-bulk-memory --enable-nontrapping-float-to-int --graph-file exports.json zig-out/bin/gitmode.wasm -o ../src/wasm/gitmode.dce.wasm && wasm-opt -Oz --enable-simd --enable-bulk-memory --enable-nontrapping-float-to-int ../src/wasm/gitmode.dce.wasm -o ../src/wasm/gitmode.wasm && rm ../src/wasm/gitmode.dce.wasm\",\n     \"build\": \"vite build\",\n     \"dev\": \"vite dev\",\n     \"preview\": \"vite preview\","
    },
