      "patch": "@@ -0,0 +1,8 @@\n+name: Non-Main Gatekeeper\n+on:\n+  pull_request:\n+    types: [opened, edited, synchronize, reopened]\n+\n+jobs:\n+  gatekeeper:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-non-main-gatekeeper.yml@main"
    },
    {
