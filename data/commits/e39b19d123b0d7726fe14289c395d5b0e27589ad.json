      "raw_url": "https://github.com/llm-d-incubation/llm-d-ci/raw/e39b19d123b0d7726fe14289c395d5b0e27589ad/.github%2Fworkflows%2Fprow-github.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/llm-d-ci/contents/.github%2Fworkflows%2Fprow-github.yml?ref=e39b19d123b0d7726fe14289c395d5b0e27589ad",
      "patch": "@@ -0,0 +1,12 @@\n+name: Prow Commands\n+on:\n+  issue_comment:\n+    types: [created]\n+\n+permissions:\n+  issues: write\n+  pull-requests: write\n+\n+jobs:\n+  prow:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-prow-commands.yml@main"
    },
