      "patch": "@@ -0,0 +1,6 @@\n+name: Prow Remove LGTM\n+on: pull_request\n+\n+jobs:\n+  remove-lgtm:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-prow-remove-lgtm.yml@main"
