      "patch": "@@ -0,0 +1,11 @@\n+name: Markdown Link Check\n+on:\n+  push:\n+    branches: [main]\n+  pull_request:\n+    branches: [main]\n+  workflow_dispatch:\n+\n+jobs:\n+  links:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-md-link-check.yml@main"
    },
    {
