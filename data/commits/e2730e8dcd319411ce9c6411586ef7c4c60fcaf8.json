8.473288349Z\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0}\n {\"id\":\"bd-r2c6\",\"title\":\"Implement asx_event_log API (event.h declarations have no implementation)\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"created_at\":\"2026-03-12T11:36:09.632377775Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-03-12T11:39:49.939865634Z\",\"closed_at\":\"2026-03-12T11:39:49.938380500Z\",\"close_reason\":\"Implemented event_log.c with all 8 functions from event.h: reset, emit, count, get, hash_chain, kind_str, to_json, replay_verify. Added to Makefile and asx_runtime_reset. 18 unit tests all passing.\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0}\n {\"id\":\"bd-v7l\",\"title\":\"Emit missing region_closed and obligation_abort trace events\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"bug\",\"created_at\":\"2026-03-12T11:02:45.606584563Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-03-12T11:03:35.349927550Z\",\"closed_at\":\"2026-03-12T11:03:35.345113953Z\",\"close_reason\":\"Completed\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0}\n {\"id\":\"bd-v8x\",\"title\":\"Correct trace API contract for explicit reset semantics\",\"status\":\"closed\",\"priority\":3,\"issue_type\":\"docs\",\"created_at\":\"2026-03-12T10:53:10.584077529Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-03-12T10:53:41.201624341Z\",\"closed_at\":\"2026-03-12T10:53:41.197321520Z\",\"close_reason\":\"Completed\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0}"
