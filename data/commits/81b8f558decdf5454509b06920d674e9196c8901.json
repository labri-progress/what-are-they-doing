      "patch": "@@ -842,8 +842,84 @@\n       }\n     },\n     {\n-      \"name\": \"memory_wrong_arity\",\n+      \"name\": \"memory_usage_setup\",\n       \"now_ms\": 14006,\n+      \"argv\": [\n+        \"SET\",\n+        \"mem_usage_key\",\n+        \"hello\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"simple\",\n+        \"value\": \"OK\"\n+      }\n+    },\n+    {\n+      \"name\": \"memory_usage_existing_key\",\n+      \"now_ms\": 14007,\n+      \"argv\": [\n+        \"MEMORY\",\n+        \"USAGE\",\n+        \"mem_usage_key\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"any_integer\"\n+      }\n+    },\n+    {\n+      \"name\": \"memory_usage_nonexistent_key\",\n+      \"now_ms\": 14008,\n+      \"argv\": [\n+        \"MEMORY\",\n+        \"USAGE\",\n+        \"no_such_key_mem\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"bulk\",\n+        \"value\": null\n+      }\n+    },\n+    {\n+      \"name\": \"memory_usage_with_samples\",\n+      \"now_ms\": 14009,\n+      \"argv\": [\n+        \"MEMORY\",\n+        \"USAGE\",\n+        \"mem_usage_key\",\n+        \"SAMPLES\",\n+        \"5\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"any_integer\"\n+      }\n+    },\n+    {\n+      \"name\": \"memory_usage_cleanup\",\n+      \"now_ms\": 14010,\n+      \"argv\": [\n+        \"DEL\",\n+        \"mem_usage_key\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"integer\",\n+        \"value\": 1\n+      }\n+    },\n+    {\n+      \"name\": \"memory_malloc_stats\",\n+      \"now_ms\": 14011,\n+      \"argv\": [\n+        \"MEMORY\",\n+        \"MALLOC-STATS\"\n+      ],\n+      \"expect\": {\n+        \"kind\": \"bulk\",\n+        \"value\": \"Memory allocator stats not available\"\n+      }\n+    },\n+    {\n+      \"name\": \"memory_wrong_arity\",\n+      \"now_ms\": 14012,\n       \"argv\": [\n         \"MEMORY\"\n       ],"
