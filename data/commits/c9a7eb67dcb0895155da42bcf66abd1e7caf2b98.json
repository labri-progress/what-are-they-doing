{
  "message": "fix minimap colorize_output Braille range coverage\n\nThe previous pattern '\u28c0'..='\u28ff' (U+28C0..U+28FF) only covered 64 of 256\nBraille code points. The full Braille Unicode block is U+2800..U+28FF.\nThis caused sparse Braille patterns to not receive cyan colorization.\n\nCo-Authored-By: Claude Opus 4.5 <noreply@anthropic.com>",
  "files": [
    {
      "sha": "6889cd81ce8ae7bbdb49901250caea79ba3eab9a",
      "filename": "crates/fm-render-term/src/minimap.rs",
      "status": "modified",
      "additions": 2,
      "deletions": 1,
      "changes": 3,
      "blob_url": "https://github.com/Dicklesworthstone/frankenmermaid/blob/c9a7eb67dcb0895155da42bcf66abd1e7caf2b98/crates%2Ffm-render-term%2Fsrc%2Fminimap.rs",
      "raw_url": "https://github.com/Dicklesworthstone/frankenmermaid/raw/c9a7eb67dcb0895155da42bcf66abd1e7caf2b98/crates%2Ffm-render-term%2Fsrc%2Fminimap.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankenmermaid/contents/crates%2Ffm-render-term%2Fsrc%2Fminimap.rs?ref=c9a7eb67dcb0895155da42bcf66abd1e7caf2b98",
      "patch": "@@ -489,7 +489,8 @@ fn colorize_output(output: &str) -> String {\n             '\u250c' | '\u2510' | '\u2514' | '\u2518' | '\u2500' | '\u2502' | '+' | '-' | '|' => {\n                 format!(\"\\x1b[90m{ch}\\x1b[0m\")\n             }\n-            '\u2588' | '\u2580' | '\u2584' | '\u28ff' | '\u28c0'..='\u28ff' => format!(\"\\x1b[36m{ch}\\x1b[0m\"),\n+            // Block characters and full Braille range (U+2800..=U+28FF)\n+            '\u2588' | '\u2580' | '\u2584' | '\\u{2800}'..='\\u{28FF}' => format!(\"\\x1b[36m{ch}\\x1b[0m\"),\n             _ => ch.to_string(),\n         })\n         .collect()"
    }
  ]
}
