{
  "message": "\ud83d\udc1b Show install dialog instead of sign-out on demo site (#1197)\n\nOn console.kubestellar.io (forced demo mode), clicking \"Sign Out\"\nnow opens the SetupInstructionsDialog instead of logging out.\nThe button text changes to \"Get Your Own Console\" with a download\nicon and purple styling to match the demo mode branding.\n\nThis prevents the confusing loop where users sign out and get\nimmediately auto-logged back in on the demo site.\n\nSigned-off-by: Andrew Anderson <andy@clubanderson.com>",
  "files": [
    {
      "sha": "e64c8f5f0d0fcfe3f10b5772b82d6d765c8b8347",
      "filename": "web/src/components/layout/UserProfileDropdown.tsx",
      "status": "modified",
      "additions": 31,
      "deletions": 5,
      "changes": 36,
      "blob_url": "https://github.com/kubestellar/console/blob/860cdcc41cda67451bcd57bcb9235b9e3175e803/web%2Fsrc%2Fcomponents%2Flayout%2FUserProfileDropdown.tsx",
      "raw_url": "https://github.com/kubestellar/console/raw/860cdcc41cda67451bcd57bcb9235b9e3175e803/web%2Fsrc%2Fcomponents%2Flayout%2FUserProfileDropdown.tsx",
      "contents_url": "https://api.github.com/repos/kubestellar/console/contents/web%2Fsrc%2Fcomponents%2Flayout%2FUserProfileDropdown.tsx?ref=860cdcc41cda67451bcd57bcb9235b9e3175e803",
      "patch": "@@ -1,8 +1,10 @@\n import { useState, useRef, useEffect } from 'react'\n import { useTranslation } from 'react-i18next'\n-import { User, Mail, MessageSquare, Shield, Settings, LogOut, ChevronDown, Coins, Lightbulb, Linkedin, Globe, Check } from 'lucide-react'\n+import { User, Mail, MessageSquare, Shield, Settings, LogOut, ChevronDown, Coins, Lightbulb, Linkedin, Globe, Check, Download } from 'lucide-react'\n import { useRewards, REWARD_ACTIONS } from '../../hooks/useRewards'\n import { languages } from '../../lib/i18n'\n+import { isDemoModeForced } from '../../lib/demoMode'\n+import { SetupInstructionsDialog } from '../setup/SetupInstructionsDialog'\n \n interface UserProfileDropdownProps {\n   user: {\n@@ -20,6 +22,7 @@ interface UserProfileDropdownProps {\n export function UserProfileDropdown({ user, onLogout, onPreferences, onFeedback }: UserProfileDropdownProps) {\n   const [isOpen, setIsOpen] = useState(false)\n   const [showLanguageSubmenu, setShowLanguageSubmenu] = useState(false)\n+  const [showSetupDialog, setShowSetupDialog] = useState(false)\n   const dropdownRef = useRef<HTMLDivElement>(null)\n   const { totalCoins, awardCoins } = useRewards()\n   const { t, i18n } = useTranslation()\n@@ -212,16 +215,39 @@ export function UserProfileDropdown({ user, onLogout, onPreferences, onFeedback\n             <button\n               onClick={() => {\n                 setIsOpen(false)\n-                onLogout()\n+                if (isDemoModeForced) {\n+                  setShowSetupDialog(true)\n+                } else {\n+                  onLogout()\n+                }\n               }}\n-              className=\"w-full flex items-center gap-3 px-3 py-2 text-sm text-red-400 hover:bg-red-500/10 rounded-lg transition-colors\"\n+              className={`w-full flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors ${\n+                isDemoModeForced\n+                  ? 'text-purple-400 hover:bg-purple-500/10'\n+                  : 'text-red-400 hover:bg-red-500/10'\n+              }`}\n             >\n-              <LogOut className=\"w-4 h-4\" />\n-              {t('actions.signOut')}\n+              {isDemoModeForced ? (\n+                <>\n+                  <Download className=\"w-4 h-4\" />\n+                  {t('actions.getYourOwn')}\n+                </>\n+              ) : (\n+                <>\n+                  <LogOut className=\"w-4 h-4\" />\n+                  {t('actions.signOut')}\n+                </>\n+              )}\n             </button>\n           </div>\n         </div>\n       )}\n+\n+      {/* Setup instructions dialog \u2014 shown when demo users click sign out */}\n+      <SetupInstructionsDialog\n+        isOpen={showSetupDialog}\n+        onClose={() => setShowSetupDialog(false)}\n+      />\n     </div>\n   )\n }"
    },
