{
  "message": "\ud83c\udf31 Add Crowdin configuration for translation management\n\nConfigures Crowdin to sync source strings from web/src/locales/en/*.json\nand output translations to web/src/locales/{locale}/*.json.\n\nSigned-off-by: Andrew Anderson <andy@clubanderson.com>",
  "files": [
    {
      "sha": "a593fbdede61103a9a9a4653f06198dffb5fb03a",
      "filename": "crowdin.yml",
      "status": "added",
      "additions": 10,
      "deletions": 0,
      "changes": 10,
      "blob_url": "https://github.com/kubestellar/console/blob/75c1322ca41f7bcd5c79c16a69ba0183f1bd3be7/crowdin.yml",
      "raw_url": "https://github.com/kubestellar/console/raw/75c1322ca41f7bcd5c79c16a69ba0183f1bd3be7/crowdin.yml",
      "contents_url": "https://api.github.com/repos/kubestellar/console/contents/crowdin.yml?ref=75c1322ca41f7bcd5c79c16a69ba0183f1bd3be7",
      "patch": "@@ -0,0 +1,10 @@\n+\"project_id_env\": \"CROWDIN_PROJECT_ID\"\n+\"api_token_env\": \"CROWDIN_PERSONAL_TOKEN\"\n+\"base_path\": \".\"\n+\"base_url\": \"https://api.crowdin.com\"\n+\n+\"preserve_hierarchy\": true\n+\n+files:\n+  - source: \"/web/src/locales/en/*.json\"\n+    translation: \"/web/src/locales/%two_letters_code%/%original_file_name%\""
    }
  ]
}
