{
  "message": "\ud83c\udf31 Add governance workflows and tooling conformance (#15)\n\nSigned-off-by: Andrew Anderson <andy@clubanderson.com>",
  "files": [
    {
      "sha": "2b374bf714a29bced1184a0fe51a22f601ebb621",
      "filename": ".github/workflows/ci-signed-commits.yaml",
      "status": "added",
      "additions": 9,
      "deletions": 0,
      "changes": 9,
      "blob_url": "https://github.com/llm-d-incubation/llm-d-async/blob/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fci-signed-commits.yaml",
      "raw_url": "https://github.com/llm-d-incubation/llm-d-async/raw/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fci-signed-commits.yaml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/llm-d-async/contents/.github%2Fworkflows%2Fci-signed-commits.yaml?ref=961f84fe0e020e616fd88105467ebedfc046f279",
      "patch": "@@ -0,0 +1,9 @@\n+name: Check Signed Commits\n+on: pull_request_target\n+\n+jobs:\n+  signed-commits:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-signed-commits.yml@main\n+    permissions:\n+      contents: read\n+      pull-requests: write"
    },
    {
      "sha": "03bd4d37aea8931e2753360a4eb9a8fc36107180",
      "filename": ".github/workflows/non-main-gatekeeper.yml",
      "status": "added",
      "additions": 8,
      "deletions": 0,
      "changes": 8,
      "blob_url": "https://github.com/llm-d-incubation/llm-d-async/blob/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fnon-main-gatekeeper.yml",
      "raw_url": "https://github.com/llm-d-incubation/llm-d-async/raw/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fnon-main-gatekeeper.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/llm-d-async/contents/.github%2Fworkflows%2Fnon-main-gatekeeper.yml?ref=961f84fe0e020e616fd88105467ebedfc046f279",
      "patch": "@@ -0,0 +1,8 @@\n+name: Non-Main Gatekeeper\n+on:\n+  pull_request:\n+    types: [opened, edited, synchronize, reopened]\n+\n+jobs:\n+  gatekeeper:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-non-main-gatekeeper.yml@main"
    },
    {
      "sha": "6fe0b234dd4fc24f0ad123da21f3b171a53cd2f3",
      "filename": ".github/workflows/prow-github.yml",
      "status": "added",
      "additions": 12,
      "deletions": 0,
      "changes": 12,
      "blob_url": "https://github.com/llm-d-incubation/llm-d-async/blob/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fprow-github.yml",
      "raw_url": "https://github.com/llm-d-incubation/llm-d-async/raw/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fprow-github.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/llm-d-async/contents/.github%2Fworkflows%2Fprow-github.yml?ref=961f84fe0e020e616fd88105467ebedfc046f279",
      "patch": "@@ -0,0 +1,12 @@\n+name: Prow Commands\n+on:\n+  issue_comment:\n+    types: [created]\n+\n+permissions:\n+  issues: write\n+  pull-requests: write\n+\n+jobs:\n+  prow:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-prow-commands.yml@main"
    },
    {
      "sha": "b837684e8eb875f8b7267711ba58e87d90b47d6e",
      "filename": ".github/workflows/prow-pr-automerge.yml",
      "status": "added",
      "additions": 8,
      "deletions": 0,
      "changes": 8,
      "blob_url": "https://github.com/llm-d-incubation/llm-d-async/blob/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fprow-pr-automerge.yml",
      "raw_url": "https://github.com/llm-d-incubation/llm-d-async/raw/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fprow-pr-automerge.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/llm-d-async/contents/.github%2Fworkflows%2Fprow-pr-automerge.yml?ref=961f84fe0e020e616fd88105467ebedfc046f279",
      "patch": "@@ -0,0 +1,8 @@\n+name: Prow Auto-merge\n+on:\n+  schedule:\n+    - cron: \"*/5 * * * *\"\n+\n+jobs:\n+  auto-merge:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-prow-automerge.yml@main"
    },
    {
      "sha": "7625ee2a1ee092f2df6db8c7c739801e69f78b34",
      "filename": ".github/workflows/prow-pr-remove-lgtm.yml",
      "status": "added",
      "additions": 6,
      "deletions": 0,
      "changes": 6,
      "blob_url": "https://github.com/llm-d-incubation/llm-d-async/blob/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fprow-pr-remove-lgtm.yml",
      "raw_url": "https://github.com/llm-d-incubation/llm-d-async/raw/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fprow-pr-remove-lgtm.yml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/llm-d-async/contents/.github%2Fworkflows%2Fprow-pr-remove-lgtm.yml?ref=961f84fe0e020e616fd88105467ebedfc046f279",
      "patch": "@@ -0,0 +1,6 @@\n+name: Prow Remove LGTM\n+on: pull_request\n+\n+jobs:\n+  remove-lgtm:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-prow-remove-lgtm.yml@main"
    },
    {
      "sha": "af558dbf495e44aad44b120aaca6f337bfca046b",
      "filename": ".github/workflows/stale.yaml",
      "status": "added",
      "additions": 11,
      "deletions": 0,
      "changes": 11,
      "blob_url": "https://github.com/llm-d-incubation/llm-d-async/blob/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fstale.yaml",
      "raw_url": "https://github.com/llm-d-incubation/llm-d-async/raw/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Fstale.yaml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/llm-d-async/contents/.github%2Fworkflows%2Fstale.yaml?ref=961f84fe0e020e616fd88105467ebedfc046f279",
      "patch": "@@ -0,0 +1,11 @@\n+name: Mark Stale Issues\n+on:\n+  schedule:\n+    - cron: '0 1 * * *'\n+\n+jobs:\n+  stale:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-stale.yml@main\n+    permissions:\n+      issues: write\n+      pull-requests: write"
    },
    {
      "sha": "5f85771742cbc7792ff7b74e3a252240b1403236",
      "filename": ".github/workflows/unstale.yaml",
      "status": "added",
      "additions": 12,
      "deletions": 0,
      "changes": 12,
      "blob_url": "https://github.com/llm-d-incubation/llm-d-async/blob/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Funstale.yaml",
      "raw_url": "https://github.com/llm-d-incubation/llm-d-async/raw/961f84fe0e020e616fd88105467ebedfc046f279/.github%2Fworkflows%2Funstale.yaml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/llm-d-async/contents/.github%2Fworkflows%2Funstale.yaml?ref=961f84fe0e020e616fd88105467ebedfc046f279",
      "patch": "@@ -0,0 +1,12 @@\n+name: Unstale Issues\n+on:\n+  issues:\n+    types: [reopened]\n+  issue_comment:\n+    types: [created]\n+\n+jobs:\n+  unstale:\n+    uses: llm-d/llm-d-infra/.github/workflows/reusable-unstale.yml@main\n+    permissions:\n+      issues: write"
    },
    {
      "sha": "47571c63e95dd1d66d6c65417ddddd6c029e538a",
      "filename": ".pre-commit-config.yaml",
      "status": "added",
      "additions": 15,
      "deletions": 0,
      "changes": 15,
      "blob_url": "https://github.com/llm-d-incubation/llm-d-async/blob/961f84fe0e020e616fd88105467ebedfc046f279/.pre-commit-config.yaml",
      "raw_url": "https://github.com/llm-d-incubation/llm-d-async/raw/961f84fe0e020e616fd88105467ebedfc046f279/.pre-commit-config.yaml",
      "contents_url": "https://api.github.com/repos/llm-d-incubation/llm-d-async/contents/.pre-commit-config.yaml?ref=961f84fe0e020e616fd88105467ebedfc046f279",
      "patch": "@@ -0,0 +1,15 @@\n+repos:\n+  # general pre-commit hooks\n+  - repo: https://github.com/pre-commit/pre-commit-hooks\n+    rev: v6.0.0\n+    hooks:\n+      - id: trailing-whitespace\n+      - id: end-of-file-fixer\n+      - id: check-yaml\n+        args: [--unsafe]  # allows custom YAML tags used in k8s\n+      - id: check-json\n+      - id: check-added-large-files\n+        args: [--maxkb=1000]\n+      - id: check-merge-conflict\n+      - id: mixed-line-ending\n+      - id: check-case-conflict"
    }
  ]
}
