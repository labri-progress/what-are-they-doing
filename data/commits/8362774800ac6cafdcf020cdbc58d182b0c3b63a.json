{
  "message": "fix: add styled markdown components to feature request preview (#3589)\n\nThe markdown preview tab in FeatureRequestModal was using ReactMarkdown\nwithout custom components, so code blocks, tables, and blockquotes\nrendered with default unstyled HTML. Now uses styled components matching\nthe rest of the app.\n\nFixes #3583\n\nSigned-off-by: Andy Anderson <andy@clubanderson.com>\nCo-authored-by: Claude Opus 4.6 <noreply@anthropic.com>",
  "files": [
    {
      "sha": "c6862da4be6a3183bcd6ad017220941534ce0677",
      "filename": "web/src/components/feedback/FeatureRequestModal.tsx",
      "status": "modified",
      "additions": 25,
      "deletions": 1,
      "changes": 26,
      "blob_url": "https://github.com/kubestellar/console/blob/8362774800ac6cafdcf020cdbc58d182b0c3b63a/web%2Fsrc%2Fcomponents%2Ffeedback%2FFeatureRequestModal.tsx",
      "raw_url": "https://github.com/kubestellar/console/raw/8362774800ac6cafdcf020cdbc58d182b0c3b63a/web%2Fsrc%2Fcomponents%2Ffeedback%2FFeatureRequestModal.tsx",
      "contents_url": "https://api.github.com/repos/kubestellar/console/contents/web%2Fsrc%2Fcomponents%2Ffeedback%2FFeatureRequestModal.tsx?ref=8362774800ac6cafdcf020cdbc58d182b0c3b63a",
      "patch": "@@ -1361,7 +1361,31 @@ export function FeatureRequestModal({ isOpen, onClose, initialTab, initialReques\n                   ) : (\n                     <div className=\"w-full h-[200px] overflow-y-auto px-3 py-2 bg-secondary/50 border border-border rounded-lg text-sm prose prose-invert prose-sm max-w-none\">\n                       {description.trim() ? (\n-                        <ReactMarkdown remarkPlugins={[remarkGfm, remarkBreaks]}>\n+                        <ReactMarkdown\n+                          remarkPlugins={[remarkGfm, remarkBreaks]}\n+                          components={{\n+                            code({ className, children, ...props }) {\n+                              const match = /language-(\\w+)/.exec(className || '')\n+                              const isInline = !match && !className\n+                              return isInline ? (\n+                                <code className=\"bg-black/20 px-1 rounded text-purple-300\" {...props}>{children}</code>\n+                              ) : (\n+                                <pre className=\"bg-black/30 rounded-lg p-3 overflow-x-auto my-2\">\n+                                  <code className={className} {...props}>{children}</code>\n+                                </pre>\n+                              )\n+                            },\n+                            table: ({ children }) => (\n+                              <div className=\"overflow-x-auto w-full my-3 rounded border border-border\">\n+                                <table className=\"min-w-full border-collapse text-sm\">{children}</table>\n+                              </div>\n+                            ),\n+                            thead: ({ children }) => <thead className=\"bg-secondary/50\">{children}</thead>,\n+                            th: ({ children }) => <th className=\"px-3 py-2 text-left text-xs font-semibold border-b border-border\">{children}</th>,\n+                            td: ({ children }) => <td className=\"px-3 py-2 text-xs border-b border-border/50\">{children}</td>,\n+                            blockquote: ({ children }) => <blockquote className=\"border-l-4 border-purple-500/50 pl-3 my-3 text-muted-foreground italic\">{children}</blockquote>,\n+                          }}\n+                        >\n                           {description}\n                         </ReactMarkdown>\n                       ) : ("
    }
  ]
}
