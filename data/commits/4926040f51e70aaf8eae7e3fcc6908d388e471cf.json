      "patch": "@@ -390,7 +390,7 @@ fn format_shape_tuple(shape: &[usize]) -> String {\n                 .map(ToString::to_string)\n                 .collect::<Vec<_>>()\n                 .join(\", \");\n-            format!(\"({joined},)\")\n+            format!(\"({joined})\")\n         }\n     }\n }"
