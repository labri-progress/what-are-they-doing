      "patch": "@@ -36,8 +36,8 @@ <h1>capnwasm <span class=\"dim\">RPC bench</span></h1>\n       </nav>\n     </header>\n \n-    <div id=\"server-status\" class=\"server-status\">\n-      <span id=\"server-dot\" class=\"dot\"></span>\n+    <div id=\"server-status\" class=\"server-status\" role=\"status\" aria-live=\"polite\">\n+      <span id=\"server-dot\" class=\"dot\" aria-hidden=\"true\"></span>\n       <span id=\"server-msg\">Checking RPC server&hellip;</span>\n       <a id=\"server-help\" class=\"server-help\" href=\"https://github.com/teamchong/capnwasm/blob/main/web/README.md\">help</a>\n     </div>\n@@ -52,7 +52,7 @@ <h1>capnwasm <span class=\"dim\">RPC bench</span></h1>\n           <option value=\"10\">10 (median)</option>\n         </select>\n       </label>\n-      <span id=\"status\"></span>\n+      <span id=\"status\" role=\"status\" aria-live=\"polite\" aria-atomic=\"true\"></span>\n     </div>\n \n     <div id=\"results-rpc\">\n@@ -122,7 +122,7 @@ <h3>Big binary &mdash; <code>echoBinary(64 KB)</code> round-trip</h3>\n       </div>\n     </div>\n \n-    <div id=\"summary\"></div>\n+    <div id=\"summary\" role=\"status\" aria-live=\"polite\"></div>\n   </div>\n \n   <script type=\"module\" src=\"./src/rpc/main.ts\"></script>"
