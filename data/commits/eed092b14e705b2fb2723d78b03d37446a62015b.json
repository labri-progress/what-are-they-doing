      "sha": "16cfd145848c1abe6f4e26855251a85d3cbf9567",
      "filename": "scripts/secret-scan-test.sh",
      "status": "modified",
      "additions": 3,
      "deletions": 0,
      "changes": 3,
      "blob_url": "https://github.com/kubestellar/console/blob/eed092b14e705b2fb2723d78b03d37446a62015b/scripts%2Fsecret-scan-test.sh",
      "raw_url": "https://github.com/kubestellar/console/raw/eed092b14e705b2fb2723d78b03d37446a62015b/scripts%2Fsecret-scan-test.sh",
