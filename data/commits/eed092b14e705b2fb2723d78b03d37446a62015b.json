      "patch": "@@ -80,8 +80,11 @@ useDefault = true\n # Allowlist paths that are expected to contain example/test secrets\n [allowlist]\n   paths = [\n+    '''\\.env$''',\n+    '''\\.env\\.local$''',\n     '''\\.env\\.example$''',\n     '''\\.env\\.template$''',\n+    '''\\.env\\.\\w+\\.local$''',\n     '''web/e2e/''',\n     '''pkg/test/''',\n     '''vendor/''',"
